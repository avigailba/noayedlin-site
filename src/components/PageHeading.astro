---
interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  variant?: 'default' | 'with-aside';
}

const { eyebrow, title, subtitle, variant = 'default' } = Astro.props;
---

<header class={`page-heading page-heading--${variant}`}>
  <div class="page-heading__main">
    <div class="page-heading__eyebrow">{eyebrow}</div>
    <h1 class="page-heading__title">{title}</h1>
    {subtitle && <p class="page-heading__subtitle">{subtitle}</p>}
  </div>
  <slot name="aside" />
</header>

<style>
  .page-heading {
    text-align: left;
    padding: 32px 0 40px;
  }

  .page-heading__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .page-heading__title {
    font-family: var(--font-serif);
    font-size: 96px;
    line-height: 0.92;
    letter-spacing: -0.035em;
    font-weight: 400;
    color: var(--text);
    margin: 0 0 22px;
  }

  .page-heading__subtitle {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-md);
    line-height: var(--lh-snug);
    color: var(--text-muted);
    max-width: 460px;
    margin: 0;
  }

  .page-heading--with-aside {
    display: grid;
    grid-template-columns: 1fr 30%;
    gap: 32px;
    align-items: start;
  }

  @media (max-width: 768px) {
    .page-heading {
      padding: 20px 0 32px;
    }
    .page-heading__title {
      font-size: clamp(48px, 12vw, 96px);
      margin-bottom: 16px;
    }
    .page-heading--with-aside {
      grid-template-columns: 1fr;
    }
  }
</style>
