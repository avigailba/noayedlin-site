---
import Layout from '../layouts/Layout.astro';
import PageHeading from '../components/PageHeading.astro';
import BooksRail from '../components/BooksRail.astro';
---

<Layout title="Contact" lang="en">
  <PageHeading
    eyebrow="Contact"
    title="Get in touch."
    subtitle="For literary rights, film & TV rights, lecture bookings, and general inquiries — please reach out to the relevant representative below."
  />

  <div class="rep-list">
    <article class="rep-row">
      <div class="rep-meta">
        <div class="rep-role">Literary agent</div>
      </div>
      <div class="rep-content">
        <div class="rep-agency">Curtis Brown</div>
        <a class="link-accent" href="https://www.curtisbrown.co.uk/client/noa-yedlin" target="_blank" rel="noopener">curtisbrown.co.uk</a>
      </div>
    </article>
    <article class="rep-row">
      <div class="rep-meta">
        <div class="rep-role">Lecture agent — USA</div>
      </div>
      <div class="rep-content">
        <div class="rep-agency">Lion House Agency</div>
        <a class="link-accent" href="https://lionhouseagency.com/noa-yedlin" target="_blank" rel="noopener">lionhouseagency.com</a>
      </div>
    </article>
    <article class="rep-row">
      <div class="rep-meta">
        <div class="rep-role">Lecture agent — Israel</div>
      </div>
      <div class="rep-content">
        <a class="link-accent" href="mailto:info@hamartzim.co.il">info@hamartzim.co.il</a>
        <div class="rep-phone">+972-3-7208856</div>
      </div>
    </article>
    <article class="rep-row">
      <div class="rep-meta">
        <div class="rep-role">Film &amp; TV — Stockholm</div>
      </div>
      <div class="rep-content">
        <a class="link-accent" href="mailto:keren.shahar@keshet-tv.com">keren.shahar@keshet-tv.com</a>
      </div>
    </article>
    <article class="rep-row">
      <div class="rep-meta">
        <div class="rep-role">Film &amp; TV — other novels</div>
      </div>
      <div class="rep-content">
        <a class="link-accent" href="mailto:jgillett@wmeagency.com">jgillett@wmeagency.com</a>
      </div>
    </article>
  </div>

  <section class="books-rail-section">
    <BooksRail />
  </section>
</Layout>

<style>
  .rep-list {
    max-width: 720px;
    margin: 0 auto;
    border-bottom: 0.5px solid var(--rule);
  }

  .rep-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 32px;
    align-items: baseline;
    padding: 28px 0;
    border-top: 0.5px solid var(--rule);
  }

  .rep-role {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    margin: 0;
  }

  .rep-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .rep-agency {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    color: var(--text);
  }

  .rep-phone {
    font-size: var(--text-sm);
    color: var(--text);
  }

  @media (max-width: 600px) {
    .rep-row {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 20px 0;
    }
  }
</style>
