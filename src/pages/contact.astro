---
import Layout from '../layouts/Layout.astro';
import PageHeading from '../components/PageHeading.astro';
---

<Layout title="Contact" lang="en">
  <PageHeading
    eyebrow="Contact"
    title="Get in touch"
    subtitle="For literary rights, film & TV rights, lecture bookings, and general inquiries — please reach out to the relevant representative below."
  />

  <section class="rep-section">
    <div class="rep-list">

      <div class="rep-row">
        <div class="rep-meta">Literary agent</div>
        <div class="rep-body">
          <div class="rep-agency">Curtis Brown</div>
          <a href="https://www.curtisbrown.co.uk/client/noa-yedlin" target="_blank" rel="noopener">curtisbrown.co.uk</a>
        </div>
      </div>

      <div class="rep-row">
        <div class="rep-meta">Lecture agent — USA</div>
        <div class="rep-body">
          <div class="rep-agency">Lion House Agency</div>
          <a href="https://lionhouseagency.com/noa-yedlin" target="_blank" rel="noopener">lionhouseagency.com</a>
        </div>
      </div>

      <div class="rep-row">
        <div class="rep-meta">Lecture agent — Israel</div>
        <div class="rep-body">
          <div class="rep-agency">Hamartzim</div>
          <a href="mailto:info@hamartzim.co.il">info@hamartzim.co.il</a>
          <span class="rep-phone">+972-3-7208856</span>
        </div>
      </div>

      <div class="rep-row">
        <div class="rep-meta">Film &amp; TV — <em>Stockholm</em></div>
        <div class="rep-body">
          <div class="rep-agency">Keshet International</div>
          <a href="mailto:keren.shahar@keshet-tv.com">keren.shahar@keshet-tv.com</a>
        </div>
      </div>

      <div class="rep-row">
        <div class="rep-meta">Film &amp; TV — other novels</div>
        <div class="rep-body">
          <div class="rep-agency">Andiamo Media</div>
          <a href="mailto:jillgillett@andiamo.media">jillgillett@andiamo.media</a>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  .rep-section {
    max-width: 720px;
    padding: 48px 0 80px;
  }

  .rep-list {
    display: flex;
    flex-direction: column;
  }

  .rep-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 32px;
    padding: 24px 0;
    align-items: baseline;
  }

  .rep-meta {
    font-size: var(--text-xs);
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    padding-top: 2px;
  }

  .rep-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .rep-agency {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--text);
    line-height: var(--lh-tight);
  }

  .rep-body a {
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    align-self: flex-start;
  }

  .rep-body a:hover { opacity: 0.7; }

  .rep-phone {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .rep-section { padding: 32px 0 56px; }
    .rep-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
