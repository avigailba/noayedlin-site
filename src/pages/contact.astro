---
import Layout from '../layouts/Layout.astro';
import BooksRail from '../components/BooksRail.astro';
---

<Layout title="Contact" lang="en">
  <header class="page-heading">
    <p class="eyebrow">Contact</p>
    <h1>Get in touch.</h1>
    <p class="page-heading-intro">For rights, media, and lecture inquiries.</p>
  </header>
  <hr class="page-rule" />
  <div class="contact-grid" style="margin-top: 2.5rem;">
    <div class="contact-card">
      <h3>Literary Agent</h3>
      <p>Curtis Brown</p>
      <a href="https://www.curtisbrown.co.uk/client/noa-yedlin" target="_blank" rel="noopener">
        curtisbrown.co.uk
      </a>
    </div>
    <div class="contact-card">
      <h3>Lecture Agent – USA</h3>
      <p>Lion House Agency</p>
      <a href="https://lionhouseagency.com/noa-yedlin" target="_blank" rel="noopener">
        lionhouseagency.com
      </a>
    </div>
    <div class="contact-card">
      <h3>Lecture Agent – Israel</h3>
      <p>+972-3-7208856</p>
    </div>
  </div>

  <BooksRail divider />
</Layout>
