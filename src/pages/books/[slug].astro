---
import Layout from '../../layouts/Layout.astro';
import BooksRail from '../../components/BooksRail.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('booksEn');
  return books.map((book) => ({
    params: { slug: book.data.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const {
  title, cover, coverColor, description, synopsis, year, kind,
  reviews, purchaseLinks, selectedReviews, adaptationText, adaptations,
  awards, prizes, tagline, badge, excerpt,
} = book.data;

const allReviews = [
  ...(selectedReviews ?? []).map((r) => ({
    quote: r.quote,
    name: r.reviewer,
    pub: r.publication ?? '',
    starred: false,
  })),
  ...(reviews ?? [])
    .filter((r) => !(selectedReviews ?? []).some((s) => s.quote.startsWith(r.quote.slice(0, 40))))
    .map((r) => ({ quote: r.quote, name: r.source, pub: '', starred: r.starred ?? false })),
];

const allPrizes = [...(prizes ?? []), ...(awards ?? [])];

const allAdaptations = adaptations ??
  (adaptationText ? [{ title: '', medium: adaptationText, year: undefined }] : []);
---

<Layout title={title} lang="en">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/books">Books</a>
    <span aria-hidden="true"> / </span>
    <span>{title}</span>
  </nav>

  <section class="bd-hero">
    <div class="bd-cover-wrap" style={coverColor ? `background: ${coverColor};` : ''}>
      <img src={cover} alt={`Cover of ${title}`} />
    </div>
    <div class="bd-info">
      {(kind || year) && (
        <p class="eyebrow bd-eyebrow">
          {kind && kind !== 'Novel' ? `${kind}${year ? ' · ' : ''}` : ''}{year}
        </p>
      )}
      <h1 class="bd-title">{title}</h1>
      {badge && <p class="book-badge">{badge}</p>}
      {(allPrizes.length > 0) && (
        <div class="bd-hero-awards">
          {allPrizes.map((prize) => (
            <span class="award-badge">{prize}</span>
          ))}
        </div>
      )}
      {tagline && <p class="bd-tagline">{tagline}</p>}
      {purchaseLinks && purchaseLinks.length > 0 && (
        <div class="retailers">
          {purchaseLinks.map((link, i) => (
            <>
              {i > 0 && <span class="retailer-sep">·</span>}
              <a class="retailer-link" href={link.href} target="_blank" rel="noopener">{link.label}</a>
            </>
          ))}
        </div>
      )}
      {excerpt && (
        <div class="bd-ctas">
          <a href={excerpt} class="btn-primary">Read an excerpt</a>
        </div>
      )}
    </div>
  </section>

  <section class="bd-synopsis">
    <p class="eyebrow bd-section-eyebrow">Synopsis</p>
    <div class="bd-synopsis-body">
      {(synopsis ?? description).split('\n').filter(p => p.trim()).map((para) => (
        <p>{para}</p>
      ))}
    </div>
  </section>

  {allReviews.length > 0 && (
    <>
      <section class="bd-praise">
        <p class="eyebrow bd-section-eyebrow">Praise</p>
        <div class="bd-reviews">
          {allReviews.map((r) => (
            <div class="bd-review">
              {r.starred && <p class="kirkus-star">★ Kirkus Starred Review</p>}
              <blockquote class="praise">
                <p>"{r.quote}"</p>
                <footer class="quote-attribution">
                  <div class="quote-author">{r.name}</div>
                  {r.pub && <div class="quote-outlet">{r.pub}</div>}
                </footer>
              </blockquote>
            </div>
          ))}
        </div>
      </section>
    </>
  )}

  {allPrizes.length > 0 && (
    <>
      <section class="bd-prizes">
        <p class="eyebrow bd-section-eyebrow">Prizes</p>
        <ul class="bd-prize-list">
          {allPrizes.map((prize) => <li>{prize}</li>)}
        </ul>
      </section>
    </>
  )}

  {allAdaptations.length > 0 && (
    <>
      <section class="bd-adaptations">
        <p class="eyebrow bd-section-eyebrow">Adaptations</p>
        <ul class="bd-adaptation-list">
          {allAdaptations.map((a) => (
            <li>
              {a.title ? <><em>{a.title}</em>{' — '}</> : null}
              {a.medium}{a.year ? `, ${a.year}` : ''}
            </li>
          ))}
        </ul>
      </section>
    </>
  )}

  <BooksRail currentSlug={book.data.slug} />
</Layout>

<style>
  /* Breadcrumb */
  .breadcrumb {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    margin-bottom: 3rem;
  }
  .breadcrumb a { color: var(--text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); opacity: 1; }

  /* Hero */
  .bd-hero {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 3rem;
    align-items: start;
    margin-bottom: 0;
    padding-bottom: 3rem;
  }

  .bd-cover-wrap {
    width: 240px;
    border-radius: 1px;
    overflow: hidden;
  }

  .bd-cover-wrap img {
    width: 100%;
    display: block;
    box-shadow: var(--shadow-cover);
  }

  .bd-info {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-top: 0.25rem;
  }

  .bd-eyebrow { color: var(--accent); margin: 0; }

  .bd-title {
    font-size: 96px;
    line-height: 0.92;
    letter-spacing: -0.035em;
    font-weight: 400;
    margin: 0;
    text-align: left;
  }

  @media (max-width: 768px) {
    .bd-title { font-size: clamp(48px, 12vw, 96px); }
  }

  .bd-hero-awards {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .bd-tagline {
    font-style: italic;
    font-size: var(--text-md);
    color: var(--text-muted);
    margin: 0;
    line-height: var(--lh-snug);
    max-width: 44ch;
  }

  .bd-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  /* Section eyebrow */
  .bd-section-eyebrow {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  /* Synopsis */
  .bd-synopsis { max-width: 620px; margin: 4rem auto 0; }
  .bd-synopsis-body p { font-size: var(--text-md); line-height: var(--lh-loose); color: var(--text); margin-bottom: 1rem; }
  .bd-synopsis-body p:last-child { margin-bottom: 0; }

  /* Praise — quote styles from global .praise* rules */
  .bd-praise { margin-top: 4rem; }
  .bd-reviews {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 24px;
  }

  @media (max-width: 1024px) {
    .bd-reviews { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .bd-reviews { grid-template-columns: 1fr; }
  }

  /* Prizes */
  .bd-prizes { max-width: 620px; margin: 4rem auto 0; }
  .bd-prize-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .bd-prize-list li { font-size: var(--text-md); line-height: var(--lh-loose); color: var(--text); }

  /* Adaptations */
  .bd-adaptations { max-width: 620px; margin: 4rem auto 0; }
  .bd-adaptation-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .bd-adaptation-list li { font-size: var(--text-md); line-height: var(--lh-loose); color: var(--text); }

  @media (max-width: 680px) {
    .bd-hero { grid-template-columns: 150px 1fr; gap: 1.5rem; }
    .bd-cover-wrap { width: 150px; }
  }
</style>
