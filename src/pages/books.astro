---
import Layout from '../layouts/Layout.astro';
import PageHeading from '../components/PageHeading.astro';
import { getCollection } from 'astro:content';

const allBooks = await getCollection('booksEn');
const books = allBooks.sort((a, b) => {
  const ao = a.data.order ?? 999;
  const bo = b.data.order ?? 999;
  if (ao !== bo) return ao - bo;
  return (b.data.year ?? 0) - (a.data.year ?? 0);
});

const years = books.map(b => b.data.year).filter(Boolean) as number[];
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Books" lang="en">
  <PageHeading eyebrow="Books" title="The novels" subtitle="Award-winning literary fiction by Noa Yedlin." />
  <div class="books-list">
    {books.map((book) => (
      <div class="books-list-row">
        <div class="books-list-cover">
          <a href={`${base}/books/${book.data.slug}`}>
            <img
              src={book.data.cover.startsWith('/') ? base + book.data.cover : book.data.cover}
              alt={`Cover of ${book.data.title}`}
              style={book.data.coverColor ? `background: ${book.data.coverColor};` : ''}
            />
          </a>
        </div>
        <div class="books-list-info">
          <p class="books-list-meta">
            {book.data.kind && book.data.kind !== 'Novel' && (
              <span class="books-list-kind">{book.data.kind}</span>
            )}
            {book.data.kind && book.data.kind !== 'Novel' && book.data.year && (
              <span class="books-list-sep"> · </span>
            )}
            {book.data.year && (
              <span class="books-list-year">{book.data.year}</span>
            )}
          </p>
          <h2 class="books-list-title">
            <a href={`${base}/books/${book.data.slug}`} class="headline-link">{book.data.title}</a>
          </h2>
          {book.data.awards && book.data.awards.length > 0 && (
            <div class="books-list-awards">
              {book.data.awards.map((award) => (
                <span class="award-badge">{award}</span>
              ))}
            </div>
          )}
          {book.data.tagline && (
            <p class="books-list-tagline">{book.data.tagline}</p>
          )}
          <p class="books-list-synopsis">
            {book.data.synopsis ?? book.data.description}
          </p>
          <a href={`${base}/books/${book.data.slug}`} class="btn-primary">Read more</a>
        </div>
      </div>
    ))}
  </div>
</Layout>

<style>
  .books-list {
    max-width: 720px;
    margin: 0 auto;
  }

  .books-list-row {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 2.5rem;
    padding: 2.5rem 0;
  }

  .books-list-row + .books-list-row {
    border-top: 0.5px solid var(--rule);
  }

  .books-list-cover a {
    display: block;
  }

  .books-list-cover img {
    width: 240px;
    aspect-ratio: 2/3;
    object-fit: cover;
    box-shadow: var(--shadow-cover);
    display: block;
  }

  .books-list-info {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 0.15rem;
    align-items: flex-start;
  }

  .books-list-meta {
    margin: 0;
    line-height: 1;
  }

  .books-list-kind {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
  }

  .books-list-sep {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .books-list-year {
    font-size: var(--text-xs);
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
  }

  .books-list-title {
    font-size: var(--text-lg);
    line-height: var(--lh-tight);
    margin: 0;
  }

  .books-list-awards {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .books-list-awards .award-badge {
    color: var(--text);
  }

  .books-list-tagline {
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: 0;
    line-height: var(--lh-snug);
  }

  .books-list-synopsis {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: var(--lh-loose);
  }

  @media (max-width: 700px) {
    .books-list-row { grid-template-columns: 140px 1fr; gap: 1.5rem; padding: 2rem 0; }
    .books-list-cover img { width: 140px; }
  }

  @media (max-width: 480px) {
    .books-list-row { grid-template-columns: 110px 1fr; gap: 1.25rem; }
    .books-list-cover img { width: 110px; }
  }
</style>
