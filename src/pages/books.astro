---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('booksEn');
---

<Layout title="Books" lang="en">
  <h1>Books</h1>
  <div class="books-grid">
    {books.map((book) => (
      <a href={`/books/${book.data.slug}`} class="book-card">
        <img src={book.data.cover} alt={`Cover of ${book.data.title}`} />
        <h3>{book.data.title}</h3>
        {book.data.year && <p>{book.data.year}</p>}
        <p>{book.data.description.slice(0, 100)}…</p>
      </a>
    ))}
  </div>
</Layout>
