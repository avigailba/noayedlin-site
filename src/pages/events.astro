---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Events &amp; Lectures" lang="en">
  <header class="page-heading">
    <p class="eyebrow">Events</p>
    <h1>Lectures &amp; Events</h1>
    <p class="page-heading-intro">Readings, lectures, and public appearances.</p>
  </header>
  <hr class="page-rule" />
  <p style="color: var(--color-muted); margin-top: 2.5rem;">
    For lecture and event inquiries, please visit the <a href="/contact">Contact</a> page.
  </p>
  <div class="section" style="margin-top: 3rem;">
    <p class="section-title">Upcoming</p>
    <p style="color: var(--color-muted);">No upcoming events listed. Check back soon.</p>
  </div>
</Layout>
