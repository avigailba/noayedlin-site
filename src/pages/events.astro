---
import Layout from '../layouts/Layout.astro';
import PageHeading from '../components/PageHeading.astro';
import BooksRail from '../components/BooksRail.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Date helpers
function parseDate(str: string) {
  const [y, m, d] = str.split('-').map(Number);
  return new Date(y, m - 1, d);
}
const MONTHS_LONG = ['January','February','March','April','May','June','July','August','September','October','November','December'];

function fmtEventDate(start: Date, end: Date | null): string {
  if (end) {
    return `${MONTHS_LONG[start.getMonth()]} ${start.getDate()}–${end.getDate()}, ${start.getFullYear()}`;
  }
  return `${MONTHS_LONG[start.getMonth()]} ${start.getDate()}, ${start.getFullYear()}`;
}

// Split upcoming / past
const today = new Date(); today.setHours(0, 0, 0, 0);
function lastDay(e: typeof allEvents[0]) {
  return parseDate(e.data.date_end ?? e.data.date_start);
}
const upcoming = allEvents
  .filter(e => e.data.status !== 'past' && lastDay(e) >= today)
  .sort((a, b) => {
    const diff = a.data.date_start.localeCompare(b.data.date_start);
    return diff !== 0 ? diff : (a.data.order ?? 99) - (b.data.order ?? 99);
  });
const past = allEvents
  .filter(e => e.data.status === 'past' || lastDay(e) < today)
  .sort((a, b) => b.data.date_start.localeCompare(a.data.date_start));
---

<Layout title="Events &amp; Lectures" lang="en">

  <PageHeading eyebrow="Events" title="Lectures & events" subtitle="Upcoming talks, readings, and public appearances." />

  {allEvents.length === 0 ? (
    <div class="ev-container">
      <p class="ev-empty">Upcoming dates will appear here. Check back soon.</p>
    </div>
  ) : (
    <div class="ev-container">

      {upcoming.length > 0 && (
        <>
          <p class="ev-section-eyebrow">Upcoming</p>
          <div class="ev-rows event-rows">
            {upcoming.map((event) => {
              const start = parseDate(event.data.date_start);
              const end   = event.data.date_end ? parseDate(event.data.date_end) : null;
              const slug  = event.data.slug ?? event.id;
              const locationStr = [event.data.city, event.data.region].filter(Boolean).join(', ');
              return (
                <article class="event-row">
                  <div class="event-meta">
                    {locationStr && <div class="event-location">{locationStr}</div>}
                    <div class="event-date">{fmtEventDate(start, end)}</div>
                    {event.data.type && <div class="event-type">{event.data.type}</div>}
                  </div>
                  <div class="event-content">
                    <h3 class="event-title">
                      <a href={`${base}/events/${slug}`} class="headline-link">{event.data.title}</a>
                    </h3>
                    {event.data.description && <p class="event-description">{event.data.description}</p>}
                    <div class="event-status">
                      {event.data.status === 'details_coming_soon' && (
                        <>
                          <span class="event-dot event-dot--muted"></span>
                          <span>Details coming soon</span>
                        </>
                      )}
                      {event.data.status === 'scheduled' && (
                        <>
                          <span class="event-dot event-dot--accent"></span>
                          {event.data.url
                            ? <a href={event.data.url} target="_blank" rel="noopener">Get details →</a>
                            : <span>Get details</span>
                          }
                        </>
                      )}
                      {event.data.status === 'ticketed' && (
                        <>
                          <span class="event-dot event-dot--accent"></span>
                          {event.data.url
                            ? <a href={event.data.url} target="_blank" rel="noopener">Get tickets →</a>
                            : <span>Get tickets</span>
                          }
                        </>
                      )}
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </>
      )}

      {past.length > 0 && (
        <>
          <p class="ev-section-eyebrow ev-section-eyebrow--past">Past</p>
          <div class="ev-rows event-rows">
            {past.map((event) => {
              const start = parseDate(event.data.date_start);
              const end   = event.data.date_end ? parseDate(event.data.date_end) : null;
              const slug  = event.data.slug ?? event.id;
              const locationStr = [event.data.city, event.data.region].filter(Boolean).join(', ');
              return (
                <article class="event-row event-row--past">
                  <div class="event-meta">
                    {locationStr && <div class="event-location">{locationStr}</div>}
                    <div class="event-date">{fmtEventDate(start, end)}</div>
                    {event.data.type && <div class="event-type">{event.data.type}</div>}
                  </div>
                  <div class="event-content">
                    <h3 class="event-title">
                      <a href={`${base}/events/${slug}`} class="headline-link">{event.data.title}</a>
                    </h3>
                    {event.data.description && <p class="event-description">{event.data.description}</p>}
                    <div class="event-status">
                      <span class="event-dot event-dot--muted"></span>
                      <span>Past event</span>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </>
      )}

    </div>
  )}

  {/* <section class="books-rail-section">
    <BooksRail />
  </section> */}

</Layout>

<style>
  /* Content container */
  .ev-container {
    max-width: 900px;
  }

  .ev-empty {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--text-muted);
    margin-top: 3rem;
    text-align: center;
  }

  /* Section eyebrows */
  .ev-section-eyebrow {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    margin: 0;
    padding: 48px 0 8px;
  }

  .ev-section-eyebrow--past {
    padding-top: 56px;
  }

  /* Row styles handled by global .event-row* rules */
</style>
