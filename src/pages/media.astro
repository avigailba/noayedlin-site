---
import Layout from '../layouts/Layout.astro';
import PageHeading from '../components/PageHeading.astro';
import BooksRail from '../components/BooksRail.astro';
import { getCollection } from 'astro:content';

const allMedia = await getCollection('media');
const mediaItems = allMedia.filter(m => !m.data.draft).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(dateStr: string) {
  const [year, month] = dateStr.split('-').map(Number);
  return new Date(year, month - 1).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}

const TYPE_LABELS: Record<string, string> = {
  Essay: 'Essays',
  Interview: 'Interviews',
  Review: 'Reviews',
  Profile: 'Profiles',
  Feature: 'Features',
  Event: 'Events',
};
const existingTypes = new Set(mediaItems.map(m => m.data.type).filter(Boolean));
const languages = new Set(mediaItems.map(m => m.data.language).filter(Boolean));
const showLangFilter = languages.has('English') && languages.has('Hebrew');
---

<Layout title="Media" lang="en">
  <PageHeading eyebrow="Press" title="In the press" subtitle="Selected interviews, essays, and critical coverage of Noa Yedlin's novels — in English and Hebrew." />

  <div class="filter-bar">
    <div class="filter-chips" role="group" aria-label="Filter by type">
      <button class="chip chip--active" data-filter-type="all" aria-pressed="true">All</button>
      {Object.entries(TYPE_LABELS)
        .filter(([key]) => existingTypes.has(key as any))
        .sort(([, a], [, b]) => a.localeCompare(b))
        .map(([key, label]) => (
          <button class="chip" data-filter-type={key} aria-pressed="false">{label}</button>
        ))}
    </div>
    {showLangFilter && (
      <div class="filter-chips filter-chips--lang" role="group" aria-label="Filter by language">
        <button class="chip chip--active" data-filter-lang="English" aria-pressed="true">English</button>
        <button class="chip chip--active" data-filter-lang="Hebrew" aria-pressed="true">עברית</button>
      </div>
    )}
  </div>

  <div class="press-list-wrap">
    {mediaItems.map((item) => (
      <div
        class="press-row"
        data-row-type={item.data.type ?? ''}
        data-row-lang={item.data.language ?? ''}
      >
        <div class="press-outlet">
          <span class="press-outlet-name">{item.data.outlet}</span>
          <span class="press-date">{formatDate(item.data.date)}</span>
          {item.data.type && <span class="press-type">{item.data.type}</span>}
        </div>
        <div class="press-content">
          <h3 class="press-headline">
            {item.data.url
              ? <a href={item.data.url} target="_blank" rel="noopener" class="headline-link">{item.data.headline}</a>
              : item.data.headline}
          </h3>
          {item.data.excerpt && (
            <p class="press-excerpt">{item.data.excerpt}</p>
          )}
          {item.data.url && (
            <a href={item.data.url} target="_blank" rel="noopener" class="btn-secondary press-view-btn">View ↗</a>
          )}
        </div>
      </div>
    ))}
  </div>

  <div class="press-empty" id="press-empty" hidden>
    <p class="press-empty-msg">No items match this filter.</p>
    <button class="press-reset" id="press-reset">View all →</button>
  </div>

  {/* <section class="books-rail-section">
    <BooksRail />
  </section> */}
</Layout>

<script>
  const typeChips = document.querySelectorAll<HTMLButtonElement>('[data-filter-type]');
  const langChips = document.querySelectorAll<HTMLButtonElement>('[data-filter-lang]');
  const rows = document.querySelectorAll<HTMLElement>('[data-row-type]');
  const emptyEl = document.getElementById('press-empty')!;
  const resetBtn = document.getElementById('press-reset')!;

  let activeType = 'all';
  const activeLangs = new Set([...langChips].map(c => c.dataset.filterLang!));

  function applyFilters() {
    let visible = 0;
    rows.forEach(row => {
      const typeMatch = activeType === 'all' || row.dataset.rowType === activeType;
      const lang = row.dataset.rowLang ?? '';
      const langMatch = !lang || activeLangs.size === 0 || activeLangs.has(lang);
      row.hidden = !(typeMatch && langMatch);
      if (!row.hidden) visible++;
    });
    emptyEl.hidden = visible > 0;
  }

  typeChips.forEach(chip => {
    chip.addEventListener('click', () => {
      activeType = chip.dataset.filterType!;
      typeChips.forEach(c => {
        const active = c === chip;
        c.classList.toggle('chip--active', active);
        c.setAttribute('aria-pressed', String(active));
      });
      applyFilters();
    });
  });

  langChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const lang = chip.dataset.filterLang!;
      if (activeLangs.has(lang)) {
        if (activeLangs.size > 1) {
          activeLangs.delete(lang);
          chip.classList.remove('chip--active');
          chip.setAttribute('aria-pressed', 'false');
        }
      } else {
        activeLangs.add(lang);
        chip.classList.add('chip--active');
        chip.setAttribute('aria-pressed', 'true');
      }
      applyFilters();
    });
  });

  resetBtn.addEventListener('click', () => {
    activeType = 'all';
    typeChips.forEach(c => {
      const active = c.dataset.filterType === 'all';
      c.classList.toggle('chip--active', active);
      c.setAttribute('aria-pressed', String(active));
    });
    langChips.forEach(c => {
      activeLangs.add(c.dataset.filterLang!);
      c.classList.add('chip--active');
      c.setAttribute('aria-pressed', 'true');
    });
    applyFilters();
  });
</script>

<style>
  /* Filter bar */
  .filter-bar {
    padding: 24px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }

  .chip {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    padding: 8px 14px;
    border: 0.5px solid var(--rule);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    border-radius: 999px;
    line-height: 1;
    transition: border-color 0.15s, color 0.15s;
  }

  .chip:hover { border-color: var(--text); color: var(--text); }
  .chip--active { border-color: var(--accent); color: var(--accent); }

  /* Press list */
  .press-list-wrap {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .press-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 32px;
    align-items: baseline;
    padding: 28px 0;
    border-top: 0.5px solid var(--rule);
  }

  .press-row[hidden] { display: none; }

  .press-outlet { display: flex; flex-direction: column; gap: 8px; }

  .press-outlet-name {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text);
  }

  .press-date {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
  }

  .press-type {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
  }

  .press-headline {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: var(--lh-tight);
    letter-spacing: var(--track-tight);
    margin: 0;
  }

  .press-view-btn { margin-top: 10px; }

  .press-excerpt {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-sm);
    line-height: var(--lh-snug);
    color: var(--text-muted);
    max-width: 60ch;
    margin: 8px 0 0;
  }

  /* Empty state */
  .press-empty {
    max-width: 800px;
    margin: 3rem auto;
    padding: 0 32px;
    text-align: center;
  }

  .press-empty-msg {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-md);
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .press-reset {
    font-size: var(--text-xs);
    color: var(--accent);
    background: transparent;
    border: none;
    cursor: pointer;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }

  .press-reset:hover { opacity: 0.7; }

  /* Mobile */
  @media (max-width: 600px) {
    .press-list-wrap { padding: 0; }

    .press-row {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 20px 0;
    }

    .press-outlet {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0;
    }

    .press-outlet-name::after { content: ' · '; }
    .press-date { display: inline; margin-top: 0; }
    .press-type { display: inline; margin-top: 0; }
    .press-type::before { content: ' · '; }

    .press-headline { font-size: var(--text-md); }
  }
</style>
