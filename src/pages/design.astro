---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Design System" lang="en">
  <h1 class="ds-page-title">Design System</h1>

  <!-- COLOURS -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Colours</h2>
    <div class="ds-swatches">
      <div class="ds-swatch" style="background: var(--bg); border: 1px solid var(--rule);">
        <span class="ds-swatch-label">--bg</span>
        <span class="ds-swatch-value">#FAFAF8</span>
      </div>
      <div class="ds-swatch" style="background: var(--bg-alt); border: 1px solid var(--rule);">
        <span class="ds-swatch-label">--bg-alt</span>
        <span class="ds-swatch-value">#F2F1EA</span>
      </div>
      <div class="ds-swatch" style="background: var(--text);">
        <span class="ds-swatch-label ds-light">--text</span>
        <span class="ds-swatch-value ds-light">#1A1A1A</span>
      </div>
      <div class="ds-swatch" style="background: var(--text-muted);">
        <span class="ds-swatch-label ds-light">--text-muted</span>
        <span class="ds-swatch-value ds-light">#5C5C5A</span>
      </div>
      <div class="ds-swatch" style="background: var(--accent);">
        <span class="ds-swatch-label ds-light">--accent</span>
        <span class="ds-swatch-value ds-light">#E5512C</span>
      </div>
      <div class="ds-swatch" style="background: var(--rule); border: 1px solid var(--rule);">
        <span class="ds-swatch-label">--rule</span>
        <span class="ds-swatch-value">#D8D7D0</span>
      </div>
    </div>
  </section>

  <hr class="ds-rule" />

  <!-- TYPE SCALE -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Type Scale</h2>
    <div class="ds-type-rows">
      <div class="ds-type-row">
        <span class="ds-type-meta">--text-xs · 12px</span>
        <span style="font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--track-wide);">EYEBROW · ATTRIBUTION · METADATA</span>
      </div>
      <div class="ds-type-row">
        <span class="ds-type-meta">--text-sm · 14px</span>
        <span style="font-size: var(--text-sm);">Book rail title · Small body</span>
      </div>
      <div class="ds-type-row">
        <span class="ds-type-meta">--text-md · 16px</span>
        <span style="font-size: var(--text-md);">Default body text</span>
      </div>
      <div class="ds-type-row">
        <span class="ds-type-meta">--text-title · 18px</span>
        <span style="font-size: var(--text-title); font-family: var(--font-serif);">Noa Yedlin</span>
      </div>
      <div class="ds-type-row">
        <span class="ds-type-meta">--text-lg · 28px</span>
        <span style="font-size: var(--text-lg); font-family: var(--font-serif);">Card title · Section heading</span>
      </div>
      <div class="ds-type-row">
        <span class="ds-type-meta">--text-xl · 48px</span>
        <span style="font-size: var(--text-xl); font-family: var(--font-serif);">Page title</span>
      </div>
    </div>
  </section>

  <hr class="ds-rule" />

  <!-- FONTS -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Fonts</h2>
    <div class="ds-font-rows">
      <div class="ds-font-row">
        <span class="ds-type-meta">--font-serif · Fraunces</span>
        <span style="font-family: var(--font-serif); font-size: 1.5rem;">The quick brown fox jumps over the lazy dog</span>
      </div>
      <div class="ds-font-row">
        <span class="ds-type-meta">--font-body · Inter</span>
        <span style="font-family: var(--font-body); font-size: 1rem;">The quick brown fox jumps over the lazy dog</span>
      </div>
      <div class="ds-font-row">
        <span class="ds-type-meta">--font-serif italic</span>
        <span style="font-family: var(--font-serif); font-style: italic; font-size: 1.5rem;">The quick brown fox jumps over the lazy dog</span>
      </div>
    </div>
  </section>

  <hr class="ds-rule" />

  <!-- LETTER SPACING -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Letter Spacing</h2>
    <div class="ds-tracking-rows">
      <div class="ds-tracking-row">
        <span class="ds-type-meta">--track-tight · -0.02em</span>
        <span style="letter-spacing: var(--track-tight); font-size: var(--text-xl); font-family: var(--font-serif);">Display heading</span>
      </div>
      <div class="ds-tracking-row">
        <span class="ds-type-meta">--track-none · 0</span>
        <span style="letter-spacing: var(--track-none); font-size: var(--text-md);">Body text · No tracking</span>
      </div>
      <div class="ds-tracking-row">
        <span class="ds-type-meta">--track-wide · 0.1em</span>
        <span style="letter-spacing: var(--track-wide); font-size: var(--text-xs); text-transform: uppercase;">Eyebrow · Attribution · Label</span>
      </div>
    </div>
  </section>

  <hr class="ds-rule" />

  <!-- LINE HEIGHTS -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Line Heights</h2>
    <div class="ds-leading-grid">
      {[
        { token: '--lh-tight', value: '1.1', use: 'H1, display' },
        { token: '--lh-snug', value: '1.4', use: 'H2, H3, rail titles' },
        { token: '--lh-loose', value: '1.6', use: 'Body, synopsis, quotes' },
      ].map(({ token, value, use }) => (
        <div class="ds-leading-card">
          <p class="ds-type-meta">{token} · {value}</p>
          <p style={`line-height: ${value}; font-family: var(--font-serif); font-size: var(--text-sm); margin: 0;`}>
            A novelist of rare clarity,<br />her prose moves like water<br />finding its level.
          </p>
          <p class="ds-leading-use">{use}</p>
        </div>
      ))}
    </div>
  </section>

  <hr class="ds-rule" />

  <!-- SHADOW -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Shadow</h2>
    <div class="ds-shadow-rows">
      <div class="ds-shadow-row">
        <div class="ds-shadow-swatch">
          <img src={import.meta.env.BASE_URL.replace(/\/$/, '') + '/images/HouseArrest-fordistribution.jpg'} alt="Book cover" class="ds-shadow-img" style="box-shadow: var(--shadow-cover);" />
        </div>
        <div>
          <p class="ds-type-meta" style="margin-bottom: 0.5rem;">--shadow-cover</p>
          <p style="font-size: var(--text-sm); color: var(--text-muted); margin: 0;">4px 6px 18px rgba(31, 27, 22, 0.18)<br />Rail covers, detail page covers</p>
        </div>
      </div>
      <div class="ds-shadow-row">
        <div class="ds-shadow-swatch">
          <img src={import.meta.env.BASE_URL.replace(/\/$/, '') + '/images/HouseArrest-fordistribution.jpg'} alt="Book cover" class="ds-shadow-img" style="box-shadow: var(--shadow-cover-lg);" />
        </div>
        <div>
          <p class="ds-type-meta" style="margin-bottom: 0.5rem;">--shadow-cover-lg</p>
          <p style="font-size: var(--text-sm); color: var(--text-muted); margin: 0;">8px 14px 40px rgba(31, 27, 22, 0.24)<br />Featured hero cover</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="ds-rule" />

  <!-- BUTTONS -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Buttons</h2>
    <div class="ds-component-rows">

      <div class="ds-component-row">
        <span class="ds-type-meta">.btn-primary</span>
        <div class="ds-component-preview">
          <a href="#" class="btn-primary">Read an excerpt</a>
        </div>
        <span class="ds-component-note">Filled pill · dark bg · used for primary CTA (excerpt, main action)</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.btn-secondary</span>
        <div class="ds-component-preview">
          <a href="#" class="btn-secondary">Buy on Amazon</a>
        </div>
        <span class="ds-component-note">Outline pill · used for purchase links and secondary CTAs</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.link-accent</span>
        <div class="ds-component-preview">
          <a href="#" class="link-accent">More about the book →</a>
        </div>
        <span class="ds-component-note">Underlined accent link · used for inline navigation CTAs</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.lang-toggle</span>
        <div class="ds-component-preview">
          <a href="#" class="lang-toggle">עברית</a>
        </div>
        <span class="ds-component-note">Bordered pill · language switcher in nav</span>
      </div>

    </div>
  </section>

  <hr class="ds-rule" />

  <!-- BADGES -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Badges &amp; Labels</h2>
    <div class="ds-component-rows">

      <div class="ds-component-row">
        <span class="ds-type-meta">.award-badge</span>
        <div class="ds-component-preview">
          <p class="award-badge">Sapir Prize (2013)</p>
        </div>
        <span class="ds-component-note">Accent colour + star prefix · awards on book detail &amp; about</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.book-badge</span>
        <div class="ds-component-preview">
          <p class="book-badge" style="align-self: auto; display: inline-block;">Coming October 13th, 2026</p>
        </div>
        <span class="ds-component-note">Dark filled banner · publication date / "Coming soon" on book detail hero</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.kirkus-star</span>
        <div class="ds-component-preview">
          <p class="kirkus-star">★ Kirkus Starred Review</p>
        </div>
        <span class="ds-component-note">Accent · starred review callout above praise blockquote</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.eyebrow</span>
        <div class="ds-component-preview">
          <p class="eyebrow" style="margin:0;">Synopsis</p>
        </div>
        <span class="ds-component-note">Muted uppercase label · section headings throughout</span>
      </div>

    </div>
  </section>

  <hr class="ds-rule" />

  <!-- QUOTES -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Quote Styles</h2>
    <div class="ds-component-rows">

      <div class="ds-component-row ds-component-row--tall">
        <span class="ds-type-meta">.quote</span>
        <div class="ds-component-preview" style="flex-direction: column; align-items: flex-start; max-width: 480px;">
          <blockquote class="quote">"All this abundance, in which one family becomes a mirror to an entire social class in Israel."</blockquote>
          <p style="font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--track-wide); color: var(--text-muted); margin: 0; padding-left: 20px;">Avraham Balaban, Haaretz Books</p>
        </div>
        <span class="ds-component-note">Fraunces italic · 2px accent border-left · praise blockquotes</span>
      </div>

      <div class="ds-component-row ds-component-row--tall">
        <span class="ds-type-meta">.hp-book-quote</span>
        <div class="ds-component-preview" style="flex-direction: column; align-items: flex-start; max-width: 480px;">
          <blockquote class="hp-book-quote">"A lucid, clear, and distinct voice."</blockquote>
          <p style="font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--track-wide); color: var(--text-muted); margin: 0;">— Dorit Rabinyan</p>
        </div>
        <span class="ds-component-note">Same as .quote but no left border · homepage hero book panels</span>
      </div>

    </div>
  </section>

  <hr class="ds-rule" />

  <!-- DIVIDERS -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Dividers</h2>
    <div class="ds-divider-rows">

      <div class="ds-divider-row">
        <span class="ds-type-meta">0.5px solid var(--rule)</span>
        <div style="flex: 1; border-top: 0.5px solid var(--rule); margin-top: 0.5rem;"></div>
        <span class="ds-component-note">All dividers — nav, footer, section rules, row separators</span>
      </div>

    </div>
  </section>
</Layout>

<style>
  .ds-page-title {
    font-size: var(--text-xl);
    font-family: var(--font-serif);
    letter-spacing: var(--track-tight);
    text-align: left;
    margin-bottom: 3rem;
  }

  .ds-section {
    margin-bottom: 3rem;
  }

  .ds-section-heading {
    font-size: var(--text-xs);
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .ds-rule {
    border: none;
    border-top: 0.5px solid var(--rule);
    margin: 3rem 0;
  }

  /* Swatches */
  .ds-swatches {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .ds-swatch {
    width: 120px;
    height: 80px;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 8px 10px;
    gap: 2px;
  }

  .ds-swatch-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    font-family: monospace;
  }

  .ds-swatch-value {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-family: monospace;
  }

  .ds-swatch .ds-light { color: rgba(255,255,255,0.75); }
  .ds-swatch .ds-light.ds-swatch-value { color: rgba(255,255,255,0.5); }

  /* Type scale */
  .ds-type-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-type-row {
    display: grid;
    grid-template-columns: 260px 1fr;
    align-items: baseline;
    gap: 2rem;
    padding: 14px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .ds-type-row:first-child { border-top: 0.5px solid var(--rule); }

  .ds-type-meta {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    font-family: monospace;
    white-space: nowrap;
  }

  /* Fonts */
  .ds-font-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-font-row {
    display: grid;
    grid-template-columns: 260px 1fr;
    align-items: center;
    gap: 2rem;
    padding: 18px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .ds-font-row:first-child { border-top: 0.5px solid var(--rule); }

  /* Tracking */
  .ds-tracking-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-tracking-row {
    display: grid;
    grid-template-columns: 260px 1fr;
    align-items: center;
    gap: 2rem;
    padding: 16px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .ds-tracking-row:first-child { border-top: 0.5px solid var(--rule); }

  /* Line heights */
  .ds-leading-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .ds-leading-card {
    padding: 1.25rem;
    background: var(--bg-alt);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ds-leading-use {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--accent);
    margin: 0;
  }

  /* Shadow */
  .ds-shadow-rows {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .ds-shadow-row {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .ds-shadow-swatch {
    width: 80px;
    flex-shrink: 0;
  }

  .ds-shadow-img {
    width: 100%;
    aspect-ratio: 2/3;
    object-fit: cover;
    box-shadow: var(--shadow-cover);
  }

  /* Component rows — buttons, badges, quotes, dividers */
  .ds-component-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-component-row {
    display: grid;
    grid-template-columns: 200px 280px 1fr;
    align-items: center;
    gap: 2rem;
    padding: 16px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .ds-component-row:first-child { border-top: 0.5px solid var(--rule); }

  .ds-component-row--tall {
    align-items: start;
    padding: 20px 0;
  }

  .ds-component-preview {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .ds-component-note {
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0;
    text-transform: none;
    font-family: var(--font-body);
    line-height: 1.5;
  }

  .ds-divider-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-divider-row {
    display: grid;
    grid-template-columns: 200px 1fr 280px;
    align-items: center;
    gap: 2rem;
    padding: 20px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .ds-divider-row:first-child { border-top: 0.5px solid var(--rule); }

  @media (max-width: 680px) {
    .ds-type-row,
    .ds-font-row,
    .ds-tracking-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .ds-leading-grid { grid-template-columns: 1fr 1fr; }
    .ds-component-row,
    .ds-divider-row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .ds-component-note { white-space: normal; }
  }
</style>
