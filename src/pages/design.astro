---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Design System" lang="en">
  <h1 class="ds-page-title">Design System</h1>

  <!-- COLOURS -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Colours</h2>
    <div class="ds-swatches">
      <div class="ds-swatch" style="background: var(--bg); border: 1px solid var(--rule);">
        <span class="ds-swatch-label">--bg</span>
        <span class="ds-swatch-value">#FAFAF8</span>
      </div>
      <div class="ds-swatch" style="background: var(--bg-alt); border: 1px solid var(--rule);">
        <span class="ds-swatch-label">--bg-alt</span>
        <span class="ds-swatch-value">#F2F1EA</span>
      </div>
      <div class="ds-swatch" style="background: var(--text);">
        <span class="ds-swatch-label ds-light">--text</span>
        <span class="ds-swatch-value ds-light">#1A1A1A</span>
      </div>
      <div class="ds-swatch" style="background: var(--text-muted);">
        <span class="ds-swatch-label ds-light">--text-muted</span>
        <span class="ds-swatch-value ds-light">#3D3D3B</span>
      </div>
      <div class="ds-swatch" style="background: var(--accent);">
        <span class="ds-swatch-label ds-light">--accent</span>
        <span class="ds-swatch-value ds-light">#E5512C</span>
      </div>
      <div class="ds-swatch" style="background: var(--rule); border: 1px solid var(--rule);">
        <span class="ds-swatch-label">--rule</span>
        <span class="ds-swatch-value">#C5C4BC</span>
      </div>
      <div class="ds-swatch" style="background: var(--text-faint);">
        <span class="ds-swatch-label ds-light">--text-faint</span>
        <span class="ds-swatch-value ds-light">#5C5C5A</span>
      </div>
    </div>
    <p style="font-size: var(--text-xs); color: var(--text-muted); margin-top: 1rem;">
      <strong>--text-faint</strong> (#5C5C5A) — tertiary text: fine print, retailer label prefix.<br/>
      <strong>--bg-alt</strong> (#F2F1EA) — tinted surface: hero rail, praise band, line-height cards.
    </p>
  </section>

  <hr class="ds-rule" />

  <!-- TYPE & FONTS -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Type &amp; Fonts</h2>
    <div class="ds-type-rows">
      <div class="ds-type-row">
        <span style="font-size: var(--text-xs); font-family: var(--font-body); text-transform: uppercase; letter-spacing: var(--track-wide);">Eyebrow · Metadata</span>
        <span class="ds-type-meta">--text-xs</span><span class="ds-type-meta">12px</span><span class="ds-type-meta">Inter 400</span>
      </div>
      <div class="ds-type-row">
        <span style="font-size: var(--text-sm); font-family: var(--font-body);">Rail title · Caption · Small body</span>
        <span class="ds-type-meta">--text-sm</span><span class="ds-type-meta">14px</span><span class="ds-type-meta">Inter 400</span>
      </div>
      <div class="ds-type-row">
        <span style="font-size: var(--text-md); font-family: var(--font-body);">Default body text</span>
        <span class="ds-type-meta">--text-md</span><span class="ds-type-meta">16px</span><span class="ds-type-meta">Inter 400</span>
      </div>
      <div class="ds-type-row">
        <span style="font-size: var(--text-title); font-family: var(--font-serif);">Noa Yedlin — wordmark</span>
        <span class="ds-type-meta">--text-title</span><span class="ds-type-meta">18px</span><span class="ds-type-meta">Fraunces 400</span>
      </div>
      <div class="ds-type-row">
        <span style="font-size: var(--text-md); font-family: var(--font-serif); font-style: italic;">Praise quotes · pull quotes · taglines</span>
        <span class="ds-type-meta">--text-md</span><span class="ds-type-meta">16px</span><span class="ds-type-meta">Fraunces italic</span>
      </div>
      <div class="ds-type-row">
        <span style="font-size: var(--text-lg); font-family: var(--font-serif);">Card title · Section heading</span>
        <span class="ds-type-meta">--text-lg</span><span class="ds-type-meta">28px</span><span class="ds-type-meta">Fraunces 400</span>
      </div>
      <div class="ds-type-row">
        <span style="font-size: var(--text-xl); font-family: var(--font-serif);">Page title</span>
        <span class="ds-type-meta">--text-xl</span><span class="ds-type-meta">48px</span><span class="ds-type-meta">Fraunces 400</span>
      </div>
      <div class="ds-type-row">
        <span style="font-size: clamp(48px, 8vw, 96px); font-family: var(--font-serif); letter-spacing: var(--track-tight); line-height: var(--lh-tight);">Page H1</span>
        <span class="ds-type-meta">—</span><span class="ds-type-meta">96px</span><span class="ds-type-meta">Fraunces 400</span>
      </div>
    </div>
  </section>

  <hr class="ds-rule" />

  <!-- LETTER SPACING -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Letter Spacing</h2>
    <div class="ds-tracking-rows">
      <div class="ds-tracking-row">
        <span class="ds-type-meta">--track-tight · -0.02em</span>
        <span style="letter-spacing: var(--track-tight); font-size: var(--text-xl); font-family: var(--font-serif);">Display heading</span>
      </div>
      <div class="ds-tracking-row">
        <span class="ds-type-meta">--track-none · 0</span>
        <span style="letter-spacing: var(--track-none); font-size: var(--text-md);">Body text · No tracking</span>
      </div>
      <div class="ds-tracking-row">
        <span class="ds-type-meta">--track-wide · 0.1em</span>
        <span style="letter-spacing: var(--track-wide); font-size: var(--text-xs); text-transform: uppercase;">Eyebrow · Attribution · Label</span>
      </div>
    </div>
  </section>

  <hr class="ds-rule" />

  <!-- LINE HEIGHTS -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Line Heights</h2>
    <div class="ds-leading-grid">
      {[
        { token: '--lh-tight', value: '1.1', use: 'H1, display' },
        { token: '--lh-snug', value: '1.4', use: 'H2, H3, rail titles' },
        { token: '--lh-loose', value: '1.6', use: 'Body, synopsis, quotes' },
      ].map(({ token, value, use }) => (
        <div class="ds-leading-card">
          <p class="ds-type-meta">{token} · {value}</p>
          <p style={`line-height: ${value}; font-family: var(--font-serif); font-size: var(--text-sm); margin: 0;`}>
            A novelist of rare clarity,<br />her prose moves like water<br />finding its level.
          </p>
          <p class="ds-leading-use">{use}</p>
        </div>
      ))}
    </div>
  </section>

  <hr class="ds-rule" />

  <!-- SHADOW -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Shadow</h2>
    <div class="ds-shadow-rows">
      <div class="ds-shadow-row">
        <div class="ds-shadow-swatch">
          <img src={import.meta.env.BASE_URL.replace(/\/$/, '') + '/images/HouseArrest-fordistribution.jpg'} alt="Book cover" class="ds-shadow-img" style="box-shadow: var(--shadow-cover);" />
        </div>
        <div>
          <p class="ds-type-meta" style="margin-bottom: 0.5rem;">--shadow-cover</p>
          <p style="font-size: var(--text-sm); color: var(--text-muted); margin: 0;">4px 6px 18px rgba(31, 27, 22, 0.18)<br />Rail covers, detail page covers</p>
        </div>
      </div>
      <div class="ds-shadow-row">
        <div class="ds-shadow-swatch">
          <img src={import.meta.env.BASE_URL.replace(/\/$/, '') + '/images/HouseArrest-fordistribution.jpg'} alt="Book cover" class="ds-shadow-img" style="box-shadow: var(--shadow-cover-lg);" />
        </div>
        <div>
          <p class="ds-type-meta" style="margin-bottom: 0.5rem;">--shadow-cover-lg</p>
          <p style="font-size: var(--text-sm); color: var(--text-muted); margin: 0;">8px 14px 40px rgba(31, 27, 22, 0.24)<br />Featured hero cover</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="ds-rule" />

  <!-- BUTTONS -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Buttons</h2>
    <div class="ds-component-rows">

      <div class="ds-component-row">
        <span class="ds-type-meta">.btn-primary</span>
        <div class="ds-component-preview">
          <a href="#" class="btn-primary">Read an excerpt</a>
        </div>
        <span class="ds-component-note">Filled pill · dark bg · used for primary CTA (excerpt, main action)</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.btn-secondary</span>
        <div class="ds-component-preview">
          <a href="#" class="btn-secondary">Buy on Amazon</a>
        </div>
        <span class="ds-component-note">Outline pill · used for purchase links and secondary CTAs</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.link-accent</span>
        <div class="ds-component-preview">
          <a href="#" class="link-accent">More about the book →</a>
        </div>
        <span class="ds-component-note">Underlined accent link · used for inline navigation CTAs</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.lang-toggle</span>
        <div class="ds-component-preview">
          <a href="#" class="lang-toggle">עברית</a>
        </div>
        <span class="ds-component-note">Bordered pill · language switcher in nav</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.headline-link</span>
        <div class="ds-component-preview">
          <a href="#" class="headline-link" style="font-family: var(--font-serif); font-size: var(--text-lg);">A master at tone</a>
        </div>
        <span class="ds-component-note">Hover: accent colour + underline + sliding → arrow · applied to every clickable serif title</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.retailers</span>
        <div class="ds-component-preview">
          <div class="retailers">
            <a class="retailer-link" href="#">Amazon</a>
            <span class="retailer-sep">·</span>
            <a class="retailer-link" href="#">B&amp;N</a>
            <span class="retailer-sep">·</span>
            <a class="retailer-link" href="#">BAM</a>
          </div>
        </div>
        <span class="ds-component-note">Inline editorial purchase links separated by · — never buttons</span>
      </div>

    </div>
  </section>

  <hr class="ds-rule" />

  <!-- BADGES -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Badges &amp; Labels</h2>
    <div class="ds-component-rows">

      <div class="ds-component-row">
        <span class="ds-type-meta">.award-badge</span>
        <div class="ds-component-preview">
          <p class="award-badge">Sapir Prize (2013)</p>
        </div>
        <span class="ds-component-note">Accent colour + star prefix · awards on book detail &amp; about</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.book-badge</span>
        <div class="ds-component-preview">
          <p class="book-badge" style="align-self: auto; display: inline-block;">Coming October 13th, 2026</p>
        </div>
        <span class="ds-component-note">Dark filled banner · publication date / "Coming soon" on book detail hero</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.kirkus-star</span>
        <div class="ds-component-preview">
          <p class="kirkus-star">★ Kirkus Starred Review</p>
        </div>
        <span class="ds-component-note">Accent · starred review callout above praise blockquote</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.eyebrow</span>
        <div class="ds-component-preview">
          <p class="eyebrow" style="margin:0;">Synopsis</p>
        </div>
        <span class="ds-component-note">Muted uppercase label · section headings throughout</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.gh-badge</span>
        <div class="ds-component-preview">
          <div style="display:inline-block;background:var(--text);color:#fff;font-family:var(--font-body);font-size:11px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;padding:5px 11px;border-radius:4px;">Forthcoming · Oct 2026</div>
        </div>
        <span class="ds-component-note">Hero badge · filled dark pill, 4px radius · forthcoming / release status in featured hero</span>
      </div>

      <div class="ds-component-row">
        <span class="ds-type-meta">.book-status</span>
        <div class="ds-component-preview">
          <div class="book-status"><span class="status-dot"></span><span>Forthcoming · October 13, 2026</span></div>
        </div>
        <span class="ds-component-note">Dot + uppercase text · book detail pages and hero panels · dot is --text-muted, never accent</span>
      </div>

    </div>
  </section>

  <hr class="ds-rule" />

  <!-- QUOTES -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Quote Styles</h2>
    <div class="ds-component-rows">

      <div class="ds-component-row ds-component-row--tall">
        <span class="ds-type-meta">.praise (homepage)</span>
        <div class="ds-component-preview" style="flex-direction: column; align-items: flex-start; max-width: 480px;">
          <blockquote class="praise" style="border-left: 2px solid var(--accent); padding-left: 1.125rem;">"All this abundance, in which one family becomes a mirror to an entire social class in Israel."</blockquote>
          <footer class="quote-attribution" style="padding-left: 1.125rem;">
            <div class="quote-author">Avraham Balaban</div>
            <div class="quote-outlet">Haaretz Books</div>
            <div class="quote-book"><em>House Arrest</em></div>
          </footer>
        </div>
        <span class="ds-component-note">.praise + 2px accent border-left · homepage praise grid only · shows .quote-book (book title) since quotes are mixed</span>
      </div>

      <div class="ds-component-row ds-component-row--tall">
        <span class="ds-type-meta">.praise (book detail)</span>
        <div class="ds-component-preview" style="flex-direction: column; align-items: flex-start; max-width: 480px;">
          <blockquote class="praise">"Bright, witty, irreverent and compassionate — an astute and hilarious study of the human condition."</blockquote>
          <footer class="quote-attribution">
            <div class="quote-author">Ruby Namdar</div>
            <div class="quote-outlet">Author</div>
          </footer>
        </div>
        <span class="ds-component-note">.praise with no left border · book detail praise grid · omit .quote-book (single-book context)</span>
      </div>

      <div class="ds-component-row ds-component-row--tall">
        <span class="ds-type-meta">.quote (pull quote)</span>
        <div class="ds-component-preview" style="flex-direction: column; align-items: flex-start; max-width: 480px;">
          <blockquote class="quote">"A lucid, clear, and distinct voice."</blockquote>
        </div>
        <span class="ds-component-note">Fraunces italic · 2px accent border-left · inline pull quotes and hero panel quotes</span>
      </div>

    </div>
  </section>

  <hr class="ds-rule" />

  <!-- EVENT ROW -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Event Row</h2>
    <div style="max-width: 720px;">
      <p style="font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--track-wide); color: var(--text-muted); margin: 0 0 8px; padding-top: 0;">Upcoming</p>
      <article class="event-row">
        <div class="event-meta">
          <div class="event-location">New York, NY</div>
          <div class="event-date">June 15, 2026</div>
          <div class="event-type">Lecture</div>
        </div>
        <div class="event-content">
          <h3 class="event-title">
            <a href="#" class="headline-link">An Evening with Noa Yedlin</a>
          </h3>
          <p class="event-description">In conversation with the author.</p>
          <div class="event-status">
            <span class="event-dot event-dot--accent"></span>
            <a href="#">Get tickets →</a>
          </div>
        </div>
      </article>
      <article class="event-row">
        <div class="event-meta">
          <div class="event-location">Tel Aviv</div>
          <div class="event-date">September 3, 2026</div>
          <div class="event-type">Book Launch</div>
        </div>
        <div class="event-content">
          <h3 class="event-title">
            <a href="#" class="headline-link">House Arrest Launch Event</a>
          </h3>
          <div class="event-status">
            <span class="event-dot event-dot--muted"></span>
            <span>Details coming soon</span>
          </div>
        </div>
      </article>
    </div>
    <p style="font-size: var(--text-xs); color: var(--text-muted); margin-top: 1.5rem;">Shared pattern across <code>/events</code> listing and homepage upcoming block. 160px meta column + content column.</p>
  </section>

  <hr class="ds-rule" />

  <!-- DIVIDERS -->
  <section class="ds-section">
    <h2 class="ds-section-heading">Dividers</h2>
    <div class="ds-divider-rows">

      <div class="ds-divider-row">
        <span class="ds-type-meta">0.5px solid var(--rule)</span>
        <div style="flex: 1; border-top: 0.5px solid var(--rule); margin-top: 0.5rem;"></div>
        <span class="ds-component-note">All dividers — nav, footer, section rules, row separators</span>
      </div>

    </div>
  </section>
</Layout>

<style>
  .ds-page-title {
    font-size: var(--text-xl);
    font-family: var(--font-serif);
    letter-spacing: var(--track-tight);
    text-align: left;
    margin-bottom: 3rem;
  }

  .ds-section {
    margin-bottom: 3rem;
  }

  .ds-section-heading {
    font-size: var(--text-xs);
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .ds-rule {
    border: none;
    border-top: 0.5px solid var(--rule);
    margin: 3rem 0;
  }

  /* Swatches */
  .ds-swatches {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .ds-swatch {
    width: 120px;
    height: 80px;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 8px 10px;
    gap: 2px;
  }

  .ds-swatch-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    font-family: monospace;
  }

  .ds-swatch-value {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-family: monospace;
  }

  .ds-swatch .ds-light { color: rgba(255,255,255,0.75); }
  .ds-swatch .ds-light.ds-swatch-value { color: rgba(255,255,255,0.5); }

  /* Type scale */
  .ds-type-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-type-row {
    display: grid;
    grid-template-columns: 1fr 100px 60px 120px;
    align-items: baseline;
    gap: 1.5rem;
    padding: 14px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .ds-type-row:first-child { border-top: 0.5px solid var(--rule); }

  .ds-type-meta {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    font-family: monospace;
    white-space: nowrap;
  }

  /* Fonts */
  .ds-font-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-font-row {
    display: grid;
    grid-template-columns: 260px 1fr;
    align-items: center;
    gap: 2rem;
    padding: 18px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .ds-font-row:first-child { border-top: 0.5px solid var(--rule); }

  /* Tracking */
  .ds-tracking-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-tracking-row {
    display: grid;
    grid-template-columns: 260px 1fr;
    align-items: center;
    gap: 2rem;
    padding: 16px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .ds-tracking-row:first-child { border-top: 0.5px solid var(--rule); }

  /* Line heights */
  .ds-leading-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .ds-leading-card {
    padding: 1.25rem;
    background: var(--bg-alt);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ds-leading-use {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--accent);
    margin: 0;
  }

  /* Shadow */
  .ds-shadow-rows {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .ds-shadow-row {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .ds-shadow-swatch {
    width: 80px;
    flex-shrink: 0;
  }

  .ds-shadow-img {
    width: 100%;
    aspect-ratio: 2/3;
    object-fit: cover;
    box-shadow: var(--shadow-cover);
  }

  /* Component rows — buttons, badges, quotes, dividers */
  .ds-component-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-component-row {
    display: grid;
    grid-template-columns: 200px 280px 1fr;
    align-items: center;
    gap: 2rem;
    padding: 16px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .ds-component-row:first-child { border-top: 0.5px solid var(--rule); }

  .ds-component-row--tall {
    align-items: start;
    padding: 20px 0;
  }

  .ds-component-preview {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .ds-component-note {
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0;
    text-transform: none;
    font-family: var(--font-body);
    line-height: 1.5;
  }

  .ds-divider-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-divider-row {
    display: grid;
    grid-template-columns: 200px 1fr 280px;
    align-items: center;
    gap: 2rem;
    padding: 20px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .ds-divider-row:first-child { border-top: 0.5px solid var(--rule); }

  @media (max-width: 680px) {
    .ds-type-row,
    .ds-font-row,
    .ds-tracking-row {
      grid-template-columns: 1fr;
