---
import Layout from '../layouts/Layout.astro';
import BooksRail from '../components/BooksRail.astro';
import { getCollection } from 'astro:content';


const books = await getCollection('booksEn');
const featured = books.find((b) => b.id === 'stockholm');
const featured2 = books.find((b) => b.id === 'house-arrest');

const allEventsRaw = await getCollection('events');

// Date helpers (homepage)
function hpParseDate(str: string) {
  const [y, m, d] = str.split('-').map(Number);
  return new Date(y, m - 1, d);
}
const HP_MONTHS_ABB  = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const HP_MONTHS_LONG = ['January','February','March','April','May','June','July','August','September','October','November','December'];

const hpToday = new Date(); hpToday.setHours(0, 0, 0, 0);
const upcomingEvents = allEventsRaw
  .filter(e => {
    const last = hpParseDate(e.data.date_end ?? e.data.date_start);
    return e.data.status !== 'past' && last >= hpToday;
  })
  .sort((a, b) => {
    const diff = a.data.date_start.localeCompare(b.data.date_start);
    return diff !== 0 ? diff : (a.data.order ?? 99) - (b.data.order ?? 99);
  })
  .slice(0, 3);

function hpEventSubtitle(evs: typeof upcomingEvents) {
  if (evs.length === 0) return '';
  const nums = ['','One','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten'];
  const n = evs.length <= 10 ? nums[evs.length] : String(evs.length);
  const countries = new Set(evs.map(e => e.data.country));
  const loc = countries.size === 1
    ? (evs[0].data.country === 'United States' ? 'U.S.' : evs[0].data.country)
    : 'international';
  const months = new Set(evs.map(e => hpParseDate(e.data.date_start).getMonth()));
  const monthStr = months.size === 1 ? ` this ${HP_MONTHS_LONG[[...months][0]]}` : '';
  return `${n} ${loc} appearance${evs.length !== 1 ? 's' : ''}${monthStr}.`;
}

const allMedia = await getCollection('media');
const featuredMedia = allMedia.filter((m) => m.data.featured);
const homeMedia = (featuredMedia.length >= 5 ? featuredMedia : allMedia)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

function formatDate(dateStr: string) {
  const [year, month] = dateStr.split('-').map(Number);
  return new Date(year, month - 1).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}
---

<Layout title="Home" lang="en">

  {/* Two featured books — side by side */}
  {(featured2 || featured) && (
    <section class="hp-books-hero">
      {featured2 && (
        <div class="hp-book-col">
          <a href={`/books/${featured2.data.slug}`} class="hp-book-cover-link">
            <img src={featured2.data.cover} alt={`Cover of ${featured2.data.title}`} class="hp-book-cover" />
          </a>
          <h2 class="hp-book-title">
            <a href={`/books/${featured2.data.slug}`}>{featured2.data.title}</a>
          </h2>
          <div class="book-status">
            <span class="status-dot"></span>
            <span>Forthcoming · October 13, 2026</span>
          </div>
          <blockquote class="hp-book-quote">"A lucid, clear, and distinct voice"</blockquote>
          <p class="hp-book-attr">— Dorit Rabinyan</p>
          <div class="book-cta-group">
            <div class="retailers">
              <span class="retailers-label">Order:</span>
              <a class="retailer-link" href="https://www.amazon.com/House-Arrest-Noa-Yedlin/dp/1954404433" target="_blank" rel="noopener">Amazon</a>
            </div>
            <a href={`/books/${featured2.data.slug}`} class="btn-primary">More about the book →</a>
          </div>
        </div>
      )}

      <div class="hp-books-divider" aria-hidden="true"></div>

      {featured && (
        <div class="hp-book-col">
          <a href={`/books/${featured.data.slug}`} class="hp-book-cover-link">
            <img src={featured.data.cover} alt={`Cover of ${featured.data.title}`} class="hp-book-cover" />
          </a>
          <h2 class="hp-book-title">
            <a href={`/books/${featured.data.slug}`}>{featured.data.title}</a>
          </h2>
          {featured.data.reviews && featured.data.reviews[0] && (
            <>
              {featured.data.reviews[0].starred && <p class="kirkus-star">★ Kirkus Starred Review</p>}
              <blockquote class="hp-book-quote">"{featured.data.reviews[0].quote}"</blockquote>
              <p class="hp-book-attr">— {featured.data.reviews[0].source}</p>
            </>
          )}
          <div class="book-cta-group">
            <div class="retailers">
              <span class="retailers-label">Order:</span>
              <a class="retailer-link" href="https://www.amazon.com/Stockholm-Novel-Noa-Yedlin/dp/0063298678" target="_blank" rel="noopener">Amazon</a>
              <span class="retailer-sep">·</span>
              <a class="retailer-link" href="https://www.barnesandnoble.com/w/stockholm-noa-yedlin/1143956543" target="_blank" rel="noopener">B&amp;N</a>
              <span class="retailer-sep">·</span>
              <a class="retailer-link" href="https://www.booksamillion.com/p/Stockholm/Noa-Yedlin/9780063298675" target="_blank" rel="noopener">BAM</a>
              <span class="retailer-sep">·</span>
              <a class="retailer-link" href="https://www.harpercollins.com/products/stockholm-noa-yedlin" target="_blank" rel="noopener">HarperCollins</a>
            </div>
            <a href={`/books/${featured.data.slug}`} class="btn-primary">More about the book →</a>
          </div>
        </div>
      )}
    </section>
  )}

  {(featured2?.data.selectedReviews || featured?.data.selectedReviews) && (
    <section class="section hp-praise">
      <p class="section-title">Praise</p>
      <div class="hp-reviews-grid">
        {[
          ...(featured2?.data.selectedReviews?.slice(0, 2) ?? []).map(r => ({ ...r, book: featured2?.data.title })),
          ...(featured?.data.selectedReviews?.slice(0, 3) ?? []).map(r => ({ ...r, book: featured?.data.title })),
        ].map((r) => (
          <div class="hp-review">
            <blockquote class="hp-review-quote">"{r.quote}"</blockquote>
            <p class="hp-review-attr">
              <span class="hp-review-name">{r.reviewer}</span>
              {r.publication && <span class="hp-review-pub">{r.publication}</span>}
            </p>
            <p class="hp-review-book"><em>{r.book}</em></p>
          </div>
        ))}
      </div>
    </section>
  )}

  {upcomingEvents.length > 0 && (
    <section class="hp-events">
      <div class="hp-events-header">
        <p class="eyebrow" style="color: var(--accent); margin-bottom: 0.75rem;">Upcoming</p>
        <h2 class="hp-events-heading">Lectures &amp; Events</h2>
        <p class="hp-events-subtitle">{hpEventSubtitle(upcomingEvents)}</p>
      </div>
      <div class="hp-events-rows">
        {upcomingEvents.map((event) => {
          const start = hpParseDate(event.data.date_start);
          const end   = event.data.date_end ? hpParseDate(event.data.date_end) : null;
          const isRange = !!end;
          const slug = event.data.slug ?? event.id;
          const dayStr = isRange
            ? `${start.getDate()}–${end!.getDate()}`
            : String(start.getDate()).padStart(2, '0');
          const monthStr = HP_MONTHS_ABB[start.getMonth()].toUpperCase();
          const regionLine = [event.data.city, event.data.region].filter(Boolean).join(', ');
          const statusLabel = event.data.status === 'details_coming_soon' ? 'Details coming soon'
            : event.data.status === 'scheduled' ? 'Get details →'
            : event.data.status === 'ticketed'  ? 'Get tickets →'
            : '';
          return (
            <div class="hp-ev-row">
              <div class="hp-ev-date">
                <span class="hp-ev-day">{dayStr}</span>
                <span class="hp-ev-month">{monthStr}</span>
              </div>
              <div class="hp-ev-body">
                <p class="hp-ev-title">{event.data.title}</p>
                <p class="hp-ev-meta">{regionLine} · {statusLabel}</p>
              </div>
              <a href={`/events/${slug}`} class="hp-ev-arrow" aria-label={`More about ${event.data.title}`}>→</a>
            </div>
          );
        })}
      </div>
      <div class="hp-events-footer">
        <a href="/events" class="link-accent">All events →</a>
      </div>
    </section>
  )}

  <BooksRail />

  {homeMedia.length > 0 && (
    <section class="hp-press">
      <div class="hp-press-header">
        <p class="eyebrow hp-press-eyebrow">Press</p>
        <h2 class="hp-press-heading">In the press</h2>
      </div>
      <div class="hp-press-list">
        {homeMedia.map((item) => (
          <div class="hp-press-row">
            <div class="hp-press-outlet">
              <span class="hp-press-outlet-name">{item.data.outlet}</span>
              <span class="hp-press-date">{formatDate(item.data.date)}</span>
              {item.data.type && <span class="hp-press-type">{item.data.type}</span>}
            </div>
            <div class="hp-press-content">
              <h3 class="hp-press-headline">
                <a href={item.data.url} target="_blank" rel="noopener">{item.data.headline}</a>
              </h3>
              {item.data.excerpt && <p class="hp-press-excerpt">{item.data.excerpt}</p>}
            </div>
          </div>
        ))}
      </div>
      <div class="hp-press-footer">
        <a href="/media" class="link-accent">All press →</a>
      </div>
    </section>
  )}
</Layout>

<style>
  /* Book status indicator */
  .book-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-xs);
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  /* Bottom-anchored CTA group */
  .book-cta-group {
    margin-top: auto;
    padding-top: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .retailers {
    font-size: var(--text-xs);
    line-height: var(--lh-snug);
    white-space: nowrap;
    margin-bottom: 16px;
  }

  .retailers-label {
    font-size: var(--text-xs);
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin-right: 10px;
  }

  .retailer-link {
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    text-decoration: none;
  }

  .retailer-link:hover { opacity: 0.7; }

  .retailer-sep {
    color: var(--text-muted);
    margin: 0 6px;
  }

  .hp-reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 0;
  }

  .hp-review {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hp-review-quote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-md);
    line-height: var(--lh-loose);
    border-left: 2px solid var(--accent);
    padding-left: 1.125rem;
    margin: 0 0 0.5rem;
    color: var(--text);
  }

  .hp-review-attr {
    padding-left: 18px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .hp-review-name {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
  }

  .hp-review-pub {
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: var(--track-none);
  }

  .hp-review-book {
    padding-left: 18px;
    margin: 0;
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* Homepage events block */
  .hp-events {
    margin-bottom: 4rem;
  }

  .hp-events-header {
    text-align: center;
    padding: 56px 0 28px;
    max-width: 720px;
    margin: 0 auto;
  }

  .hp-events-heading {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: var(--lh-tight);
    letter-spacing: var(--track-tight);
    margin: 0 0 0.5rem;
    text-align: center;
  }

  .hp-events-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-md);
    color: var(--text-muted);
    margin: 0;
    line-height: var(--lh-snug);
  }

  .hp-events-rows {
    max-width: 720px;
    margin: 0 auto;
  }

  .hp-ev-row {
    display: grid;
    grid-template-columns: 90px 1fr auto;
    gap: 28px;
    align-items: center;
    padding: 22px 0;
    border-top: 0.5px solid var(--rule);
  }

  .hp-events-rows .hp-ev-row:last-child {
    border-bottom: 0.5px solid var(--rule);
  }

  .hp-ev-date {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .hp-ev-day {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--text);
    line-height: var(--lh-tight);
    letter-spacing: var(--track-tight);
  }

  .hp-ev-month {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--accent);
  }

  .hp-ev-body {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .hp-ev-title {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: 400;
    color: var(--text);
    margin: 0;
    line-height: var(--lh-tight);
  }

  .hp-ev-meta {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
    line-height: var(--lh-snug);
  }

  .hp-ev-arrow {
    font-size: var(--text-xs);
    color: var(--accent);
    text-decoration: none;
    padding: 4px;
    flex-shrink: 0;
  }

  .hp-ev-arrow:hover { opacity: 0.7; }

  .hp-events-footer {
    text-align: center;
    padding: 24px 0 56px;
    max-width: 720px;
    margin: 0 auto;
  }

  /* Press section */
  .hp-press { margin-bottom: 4rem; }

  .hp-press-header {
    text-align: center;
    padding: 56px 0 36px;
    max-width: 920px;
    margin: 0 auto;
  }

  .hp-press-eyebrow {
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .hp-press-heading {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: var(--lh-tight);
    letter-spacing: var(--track-tight);
    margin: 0;
    text-align: center;
  }

  .hp-press-list {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .hp-press-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 32px;
    align-items: baseline;
    padding: 28px 0;
    border-top: 0.5px solid var(--rule);
  }

  .hp-press-row:last-child { border-bottom: 0.5px solid var(--rule); }

  .hp-press-outlet { display: flex; flex-direction: column; }

  .hp-press-outlet-name {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text);
  }

  .hp-press-date {
    font-size: var(--text-xs);
    letter-spacing: var(--track-none);
    color: var(--text-muted);
    margin-top: 4px;
  }

  .hp-press-type {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--accent);
    margin-top: 6px;
  }

  .hp-press-headline {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: var(--lh-tight);
    letter-spacing: var(--track-tight);
    margin: 0;
  }

  .hp-press-headline a {
    color: var(--text);
    text-decoration: none;
  }

  .hp-press-headline a:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    opacity: 1;
  }

  .hp-press-excerpt {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-sm);
    line-height: var(--lh-snug);
    color: var(--text-muted);
    max-width: 60ch;
    margin: 8px 0 0;
  }

  .hp-press-footer {
    text-align: center;
    padding: 32px 0 56px;
  }

  @media (max-width: 600px) {
    .hp-press-list { padding: 0; }
    .hp-press-row {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 20px 0;
    }
    .hp-press-outlet {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: baseline;
    }
    .hp-press-outlet-name::after { content: ' · '; }
    .hp-press-date { display: inline; margin-top: 0; }
    .hp-press-type { display: inline; margin-top: 0; }
    .hp-press-type::before { content: ' · '; }
    .hp-press-headline { font-size: 20px; }
  }
</style>
