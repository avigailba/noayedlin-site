    /* Left-align homepage footer CTAs */
    .hp-events-footer, .hp-press-footer { text-align: left; }
  }
</style>

<script>
  // Measure actual header height and set --header-h CSS var
  const header = document.querySelector('.site-header');
  if (header) {
    const setH = () => document.documentElement.style.setProperty('--header-h', header.getBoundingClientRect().height + 'px');
    setH();
    new ResizeObserver(setH).observe(header);
  }

  // ── Praise carousel ──
  const QUOTES = [
    { book: 'on Stockholm',      text: "Too funny, too sad, too real, and too preposterous \u2014 just like life. Stockholm is the most entertaining book I\u2019ve read in a long time.", author: "Etgar Keret",    role: "Author" },
    { book: 'on Stockholm',      text: "Bright, witty, irreverent and compassionate\u2026 an astute and hilarious study of the human condition.",                                          author: "Ruby Namdar",   role: "Author" },
    { book: 'on Stockholm',      text: "Hilarious, refreshing, tightly plotted and vividly written. An irresistible read.",                                                               author: "Jonas Jonasson", role: "#1 New York Times bestselling author" },
    { book: 'on Stockholm',      text: "The portraits of these four friends are so vivid that as I read, I felt Avishay\u2019s friends also became mine. Unputdownable, full of intrigue, a bit of sadness, and a lot of humor.", author: "Helene Tursten", role: "Internationally bestselling author" },
    { book: 'on Stockholm',      text: "A brilliant meditation on the intricacies of friendship, aging, ego, wounds and healing.",                                                        author: "Parini Shroff",  role: "Author of The Bandit Queens" },
    { book: 'on People Like Us', text: "All this abundance, in which one family becomes a mirror to an entire social class in Israel.",                                                   author: "Avraham Balaban", role: "Haaretz Books" },
    { book: 'on People Like Us', text: "A riveting book that examines Ashkenazi society with both sarcasm and compassion.",                                                               author: "Alon Hilu",      role: "Author" },
    { book: 'on People Like Us', text: "An excellent book \u2014 a clear, distinct, and uncompromising voice that sets a high literary standard.",                                        author: "Dorit Rabinyan", role: "Author" },
    { book: 'on House Arrest',   text: "One should run, run to buy this book",                                                                                                              author: "Haaretz",        role: "" },
    { book: 'on House Arrest',   text: "A lucid, clear, and distinct voice",                                                                                                                author: "Dorit Rabinyan", role: "Author" },
  ];

  function shuffle(arr: typeof QUOTES) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  const shuffled = shuffle(QUOTES);
  let current = 0;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const bodyEl   = document.getElementById('hpc-body')!;
  const bookEl   = document.getElementById('hpc-book')!;
  const quoteEl  = document.getElementById('hpc-quote')!;
  const attrEl   = document.getElementById('hpc-attr')!;
  const prevBtn  = document.getElementById('hpc-prev')!;
  const nextBtn  = document.getElementById('hpc-next')!;
  const pauseBtn = document.getElementById('hpc-pause')!;
  const carouselEl = document.querySelector('.hp-praise-carousel')!;

  function render(idx: number) {
    const q = shuffled[idx];
    bookEl.textContent  = q.book;
    quoteEl.textContent = '\u201c' + q.text + '\u201d';
    attrEl.textContent  = q.role ? q.author.toUpperCase() + ' \u00b7 ' + q.role.toUpperCase() : q.author.toUpperCase();
  }

  async function goTo(idx: number) {
    if (!reducedMotion) {
      bodyEl.classList.add('is-leaving');
      await new Promise(r => setTimeout(r, 180));
    }
    current = ((idx % shuffled.length) + shuffled.length) % shuffled.length;
    render(current);
    if (!reducedMotion) {
      bodyEl.classList.remove('is-leaving');
    }
  }

  render(current);

  // Auto-advance every 5 seconds
  let timer = setInterval(() => goTo(current + 1), 5000);
  const resetTimer = () => { clearInterval(timer); timer = setInterval(() => goTo(current + 1), 5000); };

  // Pause / play
  let paused = false;
  pauseBtn.addEventListener('click', () => {
    paused = !paused;
    pauseBtn.textContent = paused ? '▶' : '⏸';
    pauseBtn.setAttribute('aria-label', paused ? 'Resume auto-advancing quotes' : 'Pause auto-advancing quotes');
    pauseBtn.setAttribute('aria-pressed', String(paused));
    if (paused) { clearInterval(timer); } else { resetTimer(); }
  });

  // Also pause while keyboard focus is inside the carousel
  carouselEl.addEventListener('focusin', () => { if (!paused) clearInterval(timer); });
  carouselEl.addEventListener('focusout', (e) => {
    if (!paused && !carouselEl.contains((e as FocusEvent).relatedTarget as Node)) {
      resetTimer();
    }
  });

  prevBtn.addEventListener('click', () => { goTo(current - 1); if (!paused) resetTimer(); });
  nextBtn.addEventListener('click', () => { goTo(current + 1); if (!paused) resetTimer(); });
</script>
