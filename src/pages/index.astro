---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';


const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const books = await getCollection('booksEn');
const featured2 = books.find((b) => b.id === 'house-arrest');  // primary featured
const backlist  = [
  books.find((b) => b.id === 'stockholm'),
  books.find((b) => b.id === 'people-like-us'),
  books.find((b) => b.id === 'the-wrong-book'),
].filter(Boolean);

function coverSrc(raw: string) {
  return raw.startsWith('/') ? base + raw : raw;
}


const allEventsRaw = await getCollection('events');
function hpParseDate(str: string) {
  const [y, m, d] = str.split('-').map(Number);
  return new Date(y, m - 1, d);
}
const HP_MONTHS_LONG = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const hpToday = new Date(); hpToday.setHours(0, 0, 0, 0);
const upcomingEvents = allEventsRaw
  .filter(e => {
    const last = hpParseDate(e.data.date_end ?? e.data.date_start);
    return e.data.status !== 'past' && last >= hpToday;
  })
  .sort((a, b) => {
    const diff = a.data.date_start.localeCompare(b.data.date_start);
    return diff !== 0 ? diff : (a.data.order ?? 99) - (b.data.order ?? 99);
  })
  .slice(0, 3);

const allMedia = await getCollection('media');

const allAdaptations = await getCollection('adaptations');
const featuredStill = allAdaptations.find(a => a.data.slug === 'stockholm-de')?.data?.still?.image;
const homeMedia = allMedia
  .filter(m => !m.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);


const aboutEntry = await getEntry('about', 'about');

function formatDate(dateStr: string) {
  const [year, month] = dateStr.split('-').map(Number);
  return new Date(year, month - 1).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}
---

<Layout title="Home" lang="en">

  {/* ── Full-viewport hero ── */}
  {featured2 && (
    <section class="hp-hero-frame" aria-label="Featured book">
      <div class="hp-hero-body">

        {/* Feature column — House Arrest */}
        <div class="hp-feat">
          <a href={`${base}/books/${featured2.data.slug}`} class="gh-cover-link">
            <img
              class="gh-cover"
              src={coverSrc(featured2.data.cover)}
              alt={`Cover of ${featured2.data.title}`}
              width="300" height="450"
            />
          </a>
          <div class="gh-info">
            <div class="gh-badge">Forthcoming · Oct 2026</div>
            <h1 class="gh-title">{featured2.data.title}</h1>
            <blockquote class="gh-quote">
              "A lucid, clear, and distinct voice."
              <footer class="eyebrow gh-attr">— Dorit Rabinyan</footer>
            </blockquote>
            <div class="gh-btns">
              <a class="btn-primary gh-btn" href={`${base}/books/${featured2.data.slug}`}>
                More about the book <span class="gh-arrow">→</span>
              </a>
              <a class="btn-secondary gh-btn" href="https://www.amazon.com/House-Arrest-Noa-Yedlin/dp/1954404433" target="_blank" rel="noopener noreferrer">
                Pre-order on Amazon <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new window)</span>
              </a>
            </div>
          </div>
        </div>

        <div class="hp-col-divider" aria-hidden="true"></div>

        {/* Rail column — backlist */}
        <div class="hp-rail">
          {backlist.map((book, i) => (
            <a class="gh-rail-item" href={`${base}/books/${book!.data.slug}`}>
              <img
                class="gh-rail-thumb"
                src={coverSrc(book!.data.cover)}
                alt={`Cover of ${book!.data.title}`}
                width="52" height="78"
              />
              <div class="gh-rail-text">
                <div class="gh-rail-title">{book!.data.title}</div>
                <div class="eyebrow gh-rail-year">{book!.data.year}</div>
              </div>
              <span class="gh-rail-more">View more <span class="gh-rail-arrow">→</span></span>
            </a>
          ))}
        </div>
      </div>

    </section>
  )}

  {/* ── Praise carousel ── */}
  <section class="hp-praise-carousel" aria-label="Reader praise">
    <button class="hpc-arrow" id="hpc-prev" aria-label="Previous quote">←</button>
    <div class="hpc-body" id="hpc-body">
      <div aria-live="polite" aria-atomic="true">
        <p class="hpc-book" id="hpc-book"></p>
        <blockquote class="hpc-quote" id="hpc-quote"></blockquote>
        <p class="hpc-attr" id="hpc-attr"></p>
      </div>
      <button class="hpc-pause" id="hpc-pause" aria-label="Pause auto-advancing quotes" aria-pressed="false">⏸</button>
    </div>
    <button class="hpc-arrow" id="hpc-next" aria-label="Next quote">→</button>
  </section>

  {/* ── Rail row — backlist outside hero at ≤1024px ── */}
  <div class="hp-rail-row">
    <div class="hp-rail-row-inner">
      <div class="hp-rail-row-items">
        {backlist.map((book) => (
          <a class="gh-rail-item" href={`${base}/books/${book!.data.slug}`}>
            <img
              class="gh-rail-thumb"
              src={coverSrc(book!.data.cover)}
              alt={`Cover of ${book!.data.title}`}
              width="52" height="78"
            />
            <div class="gh-rail-text">
              <div class="gh-rail-title">{book!.data.title}</div>
              <div class="eyebrow gh-rail-year">{book!.data.year}</div>
            </div>
            <span class="gh-rail-more">View more <span class="gh-rail-arrow">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </div>

  {/* ── Remaining homepage content ── */}
  <div class="hp-inner">

    {upcomingEvents.length > 0 && (
      <section class="hp-events">
        <p class="section-eyebrow">Upcoming Events</p>
        <div class="hp-events-rows event-rows">
          {upcomingEvents.map((event) => {
            const start = hpParseDate(event.data.date_start);
            const end   = event.data.date_end ? hpParseDate(event.data.date_end) : null;
            const slug  = event.data.slug ?? event.id;
            const dateStr = end
              ? `${HP_MONTHS_LONG[start.getMonth()]} ${start.getDate()}–${end.getDate()}, ${start.getFullYear()}`
              : `${HP_MONTHS_LONG[start.getMonth()]} ${start.getDate()}, ${start.getFullYear()}`;
            const locationStr = [event.data.city, event.data.region].filter(Boolean).join(', ');
            return (
              <article class="event-row">
                <div class="event-meta">
                  {locationStr && <div class="event-location">{locationStr}</div>}
                  <time class="event-date" datetime={event.data.date_start}>{dateStr}</time>
                  {event.data.type && <div class="event-type">{event.data.type}</div>}
                </div>
                <div class="event-content">
                  <h3 class="event-title">
                    <a href={`${base}/events/${slug}`} class="headline-link">{event.data.title}</a>
                  </h3>
                  {event.data.description && <p class="event-description">{event.data.description}</p>}
                  {event.data.status === 'details_coming_soon'
                    ? <span class="btn-secondary ev-details-btn ev-details-btn--disabled">Details coming soon</span>
                    : <a href={`${base}/events/${slug}`} class="btn-secondary ev-details-btn">More details →</a>
                  }
                  <div class="event-status">
                    {event.data.status === 'scheduled' && (
                      <><span class="event-dot event-dot--accent"></span>
                        {event.data.url ? <a href={event.data.url} target="_blank" rel="noopener" aria-label="Get details (opens in new window)">Get details →</a> : <span>Get details</span>}
                      </>
                    )}
                    {event.data.status === 'ticketed' && (
                      <><span class="event-dot event-dot--accent"></span>
                        {event.data.url ? <a href={event.data.url} target="_blank" rel="noopener" aria-label="Get tickets (opens in new window)">Get tickets →</a> : <span>Get tickets</span>}
                      </>
                    )}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
        <div class="hp-events-footer">
          <a href={base + '/events'} class="btn-secondary">All events →</a>
        </div>
      </section>
    )}

    {aboutEntry && (
      <section class="hp-about-strip">
        <img class="hp-about-img" src={aboutEntry.data.portrait} alt="Portrait of Noa Yedlin" />
        <div class="hp-about-text">
          <p class="eyebrow hp-about-eyebrow">About</p>
          <p class="hp-about-lead" set:html={aboutEntry.data.lead} />
          <a href={base + '/about'} class="btn-secondary">Read more →</a>
        </div>
      </section>
    )}

    {/* ── Adaptations preview ── */}
    <section class="hp-adaptations">
      <div class="hp-adaptations__text">
        <p class="section-eyebrow">Adaptations</p>
        <h2 class="hp-adaptations__title">On screen and on stage.</h2>
        <div class="hp-adaptations__body">
          <p>Yedlin is the creator of a two-season TV series based on her bestselling novel <em>Stockholm</em>, winner of the Israeli Best Mini-Series TV Award. A German remake — <em>You Don't Die Among Friends</em> — won Best Scripted Format at the 2021 International Format Awards and Best European Series at La Rochelle Festival De La Fiction 2021. The series has also been remade by SVT Sweden.</p>
          <p>Her novel <em>People Like Us</em> is currently being developed into a series in Israel, and a stage adaptation of <em>House Arrest</em> is playing at Beit Lessin Theater in Tel Aviv.</p>
        </div>
        <a href={base + '/adaptations'} class="btn-secondary">All adaptations →</a>
      </div>
      {featuredStill && (
        <div class="hp-adaptations__image">
          <img src={featuredStill} alt="Production still from Unter Freunden stirbt man nicht, the German adaptation of Stockholm" />
        </div>
      )}
    </section>

    {homeMedia.length > 0 && (
      <section class="hp-press">
        <p class="section-eyebrow">Media</p>
        <div class="hp-press-list">
          {homeMedia.map((item) => (
            <div class="press-row">
              <div class="press-outlet">
                <span class="press-outlet-name">{item.data.outlet}</span>
                <span class="press-date">{formatDate(item.data.date)}</span>
                {item.data.type && <span class="press-type">{item.data.type}</span>}
              </div>
              <div class="press-content">
                <h3 class="press-headline">
                  {item.data.url
                    ? <a href={item.data.url} target="_blank" rel="noopener" class="headline-link">{item.data.headline}</a>
                    : item.data.headline}
                </h3>
                {item.data.excerpt && <p class="press-excerpt">{item.data.excerpt}</p>}
                {item.data.url && (
                  <a href={item.data.url} target="_blank" rel="noopener" class="btn-secondary press-view-btn">View ↗</a>
                )}
              </div>
            </div>
          ))}
        </div>
        <div class="hp-press-footer">
          <a href={base + '/media'} class="btn-secondary">All Media →</a>
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  /* ── Override main on homepage: hero is full-bleed ── */
  :global(main) {
    padding: 0;
    max-width: none;
  }

  /* ── Inner wrapper restores padding for post-hero sections ── */
  .hp-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 32px 56px;
  }
  @media (max-width: 600px) {
    .hp-inner { padding: 0 20px 40px; }
  }

  /* ═══════════════════════════════════════════════════
     Hero frame — full-viewport flex column
  ═══════════════════════════════════════════════════ */
  .hp-hero-frame {
    height: max(460px, calc(75vh - var(--header-h, 68px)));
    display: flex;
    flex-direction: column;
    background: var(--bg);
    color: var(--text);
    overflow: hidden;
    position: relative;
  }

  /* Scroll-invitation gradient — fades hero bottom edge into page bg */
  .hp-hero-frame::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 48px;
    background: linear-gradient(to bottom, transparent, var(--bg));
    pointer-events: none;
    z-index: 1;
  }

  /* Body: feature + rail, clips overflow so praise band stays visible */
  .hp-hero-body {
    flex: 1;
    min-height: 0;
    display: flex;
    overflow: hidden;
  }

  .hp-col-divider {
    flex-shrink: 0;
    width: 0.5px;
    background: var(--rule);
    margin: 48px 0;
  }

  /* ── Feature column ── */
  .hp-feat {
    flex: 1.55;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: clamp(28px, 3.2vw, 46px);
    padding: 24px clamp(28px, 3vw, 40px) 24px 12%;
  }

  .gh-cover-link { display: block; flex-shrink: 0; }

  .gh-cover {
    width: clamp(160px, min(22vw, 36vh), 320px);
    height: auto;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: 3px;
    box-shadow: var(--shadow-cover-lg);
    display: block;
    transition: transform .35s cubic-bezier(.2,.7,.3,1), box-shadow .35s ease;
  }
  .gh-cover-link:hover .gh-cover {
    transform: translateY(-6px);
    box-shadow: 10px 20px 48px rgba(31, 27, 22, 0.28);
  }

  .gh-info {
    display: flex;
    flex-direction: column;
    max-width: 460px;
    min-width: 0;
  }

  .gh-badge {
    display: inline-block;
    background: var(--text);
    color: #fff;
    font-family: var(--font-body);
    font-size: clamp(0.65rem, 0.8vw, 0.75rem);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 11px;
    border-radius: 4px;
    white-space: nowrap;
    margin-bottom: 16px;
    align-self: flex-start;
  }

  .gh-title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 4.4vw, 62px);
    font-weight: 600;
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
    text-align: left; /* override global h1 center */
  }

  .gh-quote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    line-height: 1.6;
    color: var(--text);
    border: none;       /* override global .quote border */
    padding: 0;
    margin: 0 0 8px;
  }

  .gh-attr { margin: 0 0 26px; }

  /* Button row */
  .gh-btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .gh-btn {
    padding: 12px 22px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    min-width: fit-content;
    transition: transform .18s ease, background .18s ease, color .18s ease, opacity .18s ease;
  }

  .gh-btns .btn-primary.gh-btn:hover {
    opacity: 1;
    background: #000;
    transform: translateY(-1px);
  }
  .gh-btns .btn-secondary.gh-btn:hover {
    opacity: 1;
    background: var(--text);
    color: #fff;
  }

  .gh-arrow {
    display: inline-block;
    transition: transform .2s ease;
  }
  .gh-btns .btn-primary.gh-btn:hover .gh-arrow { transform: translateX(4px); }

  /* ── Rail column ── */
  .hp-rail {
    flex: 1;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(20px, 3vh, 34px) 15% clamp(20px, 3vh, 34px) clamp(28px, 2.6vw, 40px);
  }

  .hp-rail-label { margin-bottom: 20px; }

  .gh-rail-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: clamp(12px, 1.8vh, 20px) 0;
    text-decoration: none;
    color: var(--text);
  }
  .gh-rail-item + .gh-rail-item { border-top: 0.5px solid var(--rule); }

  .gh-rail-thumb {
    width: 52px;
    height: 78px;
    flex-shrink: 0;
    object-fit: cover;
    border-radius: 2px;
    box-shadow: var(--shadow-cover);
    display: block;
    transition: transform .3s cubic-bezier(.2,.7,.3,1);
  }
  .gh-rail-item:hover .gh-rail-thumb { transform: translateY(-4px); }

  .gh-rail-text { flex: 1; min-width: 0; }
  .gh-rail-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .gh-rail-year { margin-top: 4px; }

  .gh-rail-more {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text);
    white-space: nowrap;
    flex-shrink: 0;
    text-decoration: none;
    display: inline-block;
    background: transparent;
    padding: 9px 21px;
    border: 1px solid var(--text);
    letter-spacing: var(--track-none);
  }
  .gh-rail-arrow {
    display: inline-block;
    transition: transform .2s ease;
  }
  .gh-rail-item:hover .gh-rail-more {
    background: #000;
    color: #fff;
    border-color: #000;
  }
  .gh-rail-item:hover .gh-rail-arrow { transform: translateX(4px); }

  /* ── Praise carousel (full-bleed, lives outside hp-inner) ── */
  :global(.hp-praise-carousel) {
    background: var(--bg-alt);
    padding: 72px 48px;
    text-align: center;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  :global(.hpc-body) {
    flex: 1;
    max-width: 860px;
    margin: 0 auto;
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  :global(.hpc-body.is-leaving) {
    opacity: 0;
    transform: translateY(8px);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.hpc-body) { transition: none; }
  }

  :global(.hpc-book) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--accent);
    white-space: nowrap;
    margin: 0 0 24px;
  }

  :global(.hpc-quote) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(22px, 2.8vw, 36px);
    line-height: var(--lh-snug);
    letter-spacing: var(--track-none);
    color: var(--text);
    border: none;
    padding: 0;
    margin: 0 0 24px;
  }

  :global(.hpc-attr) {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0;
  }

  :global(.hpc-arrow) {
    width: 32px;
    height: 32px;
    border: 1px solid var(--rule);
    background: transparent;
    cursor: pointer;
    color: var(--text);
    font-size: 15px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s;
    flex-shrink: 0;
  }

  :global(.hpc-arrow:hover) {
    border-color: var(--text);
  }

  :global(.hpc-pause) {
    width: 32px;
    height: 32px;
    border: 1px solid var(--rule);
    background: transparent;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 13px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s, color 0.15s;
    flex-shrink: 0;
    margin-top: 16px;
  }

  :global(.hpc-pause:hover) {
    border-color: var(--text);
    color: var(--text);
  }

  @media (max-width: 768px) {
    :global(.hp-praise-carousel) { padding: 48px 20px; gap: 16px; }
    :global(.hpc-arrow) { flex-shrink: 0; }
  }

  /* ── Entrance animation — feature column only ── */
  @media (prefers-reduced-motion: no-preference) {
    .hp-feat {
      opacity: 0;
      transform: translateY(16px);
      animation: ghHeroUp .7s cubic-bezier(.2,.7,.3,1) .14s forwards;
    }
  }
  @keyframes ghHeroUp { to { opacity: 1; transform: none; } }

  /* ── 1280px: tighten column proportions ── */
  @media (max-width: 1280px) {
    .hp-feat {
      padding: 24px clamp(20px, 2.5vw, 32px) 24px 8%;
    }
    .hp-rail {
      min-width: 280px;
      max-width: 320px;
      flex: none;
      padding: clamp(20px, 3vh, 34px) 4% clamp(20px, 3vh, 34px) clamp(24px, 2vw, 32px);
    }
    .gh-info { min-width: 260px; }
  }

  /* ── 1024px: drop in-hero rail, hero becomes 2-col ── */
  @media (max-width: 1024px) {
    .hp-col-divider { display: none; }
    .hp-rail { display: none; }
    .hp-feat {
      flex: 1;
      justify-content: center;
      padding: 24px 8%;
    }
    .gh-cover {
      width: clamp(220px, 28vw, 360px);
    }
  }

  /* ── 768px: single-column, remove viewport lock ── */
  @media (max-width: 768px) {
    .hp-hero-frame {
      height: auto;
      overflow: visible;
    }
    .hp-hero-body {
      flex-direction: column;
      overflow: visible;
    }
    .hp-feat {
      flex: none;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 32px 20px;
      gap: 24px;
    }
    .gh-cover {
      width: clamp(180px, 56vw, 260px);
      align-self: center;
    }
    .gh-info {
      max-width: 100%;
      align-items: center;
    }
    .gh-badge { align-self: center; }
    .gh-title { white-space: normal; text-align: center; }
    .gh-quote, .gh-attr { text-align: center; }
    .gh-btns { justify-content: center; }
  }

  /* ── Rail row — backlist, visible ≤1024px below the praise section ── */
  .hp-rail-row { display: none; }

  @media (max-width: 1024px) {
    .hp-rail-row {
      display: block;
      background: var(--bg);
      border-top: 0.5px solid var(--rule);
    }
    .hp-rail-row-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 0;
      padding: 0 32px;
    }
    .hp-rail-row-label {
      flex-shrink: 0;
      white-space: nowrap;
      margin: 0;
      padding: 16px 20px 16px 0;
      border-right: 0.5px solid var(--rule);
    }
    .hp-rail-row-items {
      display: flex;
      flex: 1;
    }
    .hp-rail-row .gh-rail-item {
      flex: 1;
      padding: 12px 20px;
      border-top: none;
    }
    .hp-rail-row .gh-rail-item + .gh-rail-item {
      border-top: none;
      border-left: 0.5px solid var(--rule);
    }
    .hp-rail-row .gh-rail-more { display: none; }
  }

  @media (max-width: 768px) {
    .hp-rail-row-inner {
      flex-direction: column;
      align-items: stretch;
      padding: 0 20px;
      gap: 0;
    }
    .hp-rail-row-label {
      border-right: none;
      padding: 16px 0 12px;
    }
    .hp-rail-row-items {
      flex-direction: column;
      width: 100%;
    }
    .hp-rail-row .gh-rail-item {
      flex: none;
      padding: 14px 0;
      border-top: 0.5px solid var(--rule);
      border-left: none;
    }
    .hp-rail-row .gh-rail-item + .gh-rail-item {
      border-left: none;
      padding-left: 0;
    }
    .hp-rail-row .gh-rail-more { display: flex; }
  }

  /* ── Post-hero sections ── */
  .hp-events {
    padding: 64px 0;
  }
  .hp-events-rows { max-width: none; }
  .hp-events-footer {
    text-align: left;
    padding: 24px 0 0;
  }

  /* About strip */
  .hp-about-strip {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    align-items: start;
    padding: 64px 0;
    border-top: 0.5px solid var(--rule);
  }
  .hp-about-img {
    width: 100%;
    display: block;
    filter: grayscale(100%);
  }
  .hp-about-eyebrow { margin-bottom: 16px; }
  .hp-about-lead {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-loose);
    color: var(--text);
    margin-bottom: 24px;
  }
  @media (max-width: 600px) {
    .hp-about-strip {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .hp-about-img { max-width: 180px; }
  }

  /* Left-align eyebrows in events, press, adaptations sections */
  .hp-events .section-eyebrow,
  .hp-press .section-eyebrow,
  .hp-adaptations__text .section-eyebrow {
    text-align: left;
  }

  .hp-adaptations {
    display: grid;
    grid-template-columns: 1fr 1fr;
