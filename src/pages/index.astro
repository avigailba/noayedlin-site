---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('booksEn');
const featured = books.find((b) => b.id === 'stockholm');
---

<Layout title="Home" lang="en">
  <section class="hero">
    <div class="hero-text">
      <h1>Noa Yedlin</h1>
      <p>
        Israeli novelist and screenwriter. Winner of the Sapir Prize and the Prime Minister's
        Literature Award. Author of <em>Stockholm</em>, <em>House Arrest</em>,
        <em>People Like Us</em>, and <em>The Wrong Book</em>.
      </p>
      <p style="margin-top:1.5rem;">
        <a href="/books" style="text-decoration:none; border-bottom: 2px solid currentColor; padding-bottom:2px;">
          See all books →
        </a>
      </p>
    </div>
    {featured && (
      <a href={`/books/${featured.data.slug}`} class="book-card" style="max-width:260px; justify-self:center;">
        <img src={featured.data.cover} alt={`Cover of ${featured.data.title}`} />
        <h3>{featured.data.title}</h3>
        {featured.data.reviews?.[0] && (
          <p>"{featured.data.reviews[0].quote}" — {featured.data.reviews[0].source}</p>
        )}
      </a>
    )}
  </section>

  <section class="section">
    <p class="section-title">Books</p>
    <div class="books-grid">
      {books.map((book) => (
        <a href={`/books/${book.data.slug}`} class="book-card">
          <img src={book.data.cover} alt={`Cover of ${book.data.title}`} />
          <h3>{book.data.title}</h3>
          <p>{book.data.description.slice(0, 80)}…</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
