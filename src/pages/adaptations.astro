---
import Layout from '../layouts/Layout.astro';
import PageHeading from '../components/PageHeading.astro';
import BooksRail from '../components/BooksRail.astro';
import { getCollection } from 'astro:content';

const allAdaptations = await getCollection('adaptations');
const allBooks = await getCollection('booksEn');

const bookMap = Object.fromEntries(allBooks.map(b => [b.data.slug, b.data]));

const groups = allAdaptations.reduce((acc, a) => {
  const key = a.data.source_book;
  if (!acc[key]) acc[key] = [];
  acc[key].push(a);
  return acc;
}, {} as Record<string, typeof allAdaptations>);

Object.values(groups).forEach(g => g.sort((a, b) => a.data.order - b.data.order));

const sortedGroups = Object.entries(groups)
  .sort(([slugA], [slugB]) => (bookMap[slugA]?.order ?? 999) - (bookMap[slugB]?.order ?? 999))
  .filter(([slug]) => bookMap[slug]);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const countries = [...new Set(allAdaptations.map(a => a.data.country))];
const countriesText = countries.length <= 2
  ? countries.join(' and ')
  : countries.slice(0, -1).join(', ') + ', and ' + countries[countries.length - 1];

const processedGroups = sortedGroups.map(([slug, adaptationList]) => {
  const book = bookMap[slug];
  const entries = adaptationList.map(a => ({
    data: a.data,
    images: a.data.stills && a.data.stills.length > 0
      ? a.data.stills
      : a.data.still?.image ? [a.data.still.image] : [],
    imagePos: a.data.still?.position ?? 'center 20%',
    awards: a.data.awards ?? [],
    prioritized: [
      ...(a.data.watch ?? []).map(w => ({ label: w.label, url: w.url })),
      ...(a.data.info ?? []),
      ...(a.data.press ?? []),
    ],
  }));
  return { slug, book, entries, count: adaptationList.length };
});
---

<Layout title="Adaptations" lang="en">

  <PageHeading
    eyebrow="Adaptations"
    title="On screen and on stage"
    subtitle={`Television and stage adaptations of Noa Yedlin's novels, across ${countriesText}.`}
  />

  <div class="ap-page">
    {processedGroups.map(({ slug, book, entries, count }) => (
      <div class="ap-group">
        <div class="ap-group-header">
          <span class="ap-novel-title"><em>{book.title}</em></span>
          {count > 1 && <span class="ap-count">{count} adaptations</span>}
        </div>

        {entries.map(({ data, images, imagePos, awards, prioritized }) => (
          <div class={`ap-entry${images.length > 0 ? ' ap-entry--has-image' : ''}`}>

            <div class="ap-meta">
              <span class="ap-country">{data.country}</span>
              {data.medium && <span class="ap-medium">{data.medium}</span>}
              {data.year && <span class="ap-year">{data.year}</span>}
            </div>

            <div class="ap-content">
              <div class="ap-title">{data.title}</div>
              {data.network && (
                <div class="ap-network">
                  {data.network}{data.status && <em class="ap-status"> — {data.status}</em>}
                </div>
              )}
              {awards.length > 0 && (
                <div class="ap-awards">
                  {awards.map((award) => (
                    <div class="ap-award">
                      <span class="ap-award-dash">—</span>
                      <span class="ap-award-text">{award}</span>
                    </div>
                  ))}
                </div>
              )}
              {prioritized.length > 0 && (
                <div class="ap-links">
                  {prioritized.map((link, i) => (
                    <>
                      <a href={link.url} target="_blank" rel="noopener" class="ap-link">{link.label} <span aria-hidden="true">↗</span></a>
                      {i < prioritized.length - 1 && <span class="ap-sep">·</span>}
                    </>
                  ))}
                </div>
              )}
            </div>

            {images.length === 1 && (
              <div class="ap-img-wrap">
                <img src={images[0]} alt={`Production still from ${data.title}`} loading="lazy" class="ap-img" style={`object-position: ${imagePos}`} />
              </div>
            )}
            {images.length > 1 && (
              <div class="ap-img-strip-wrap">
                <div class="ap-img-strip">
                  {images.map((src, i) => (
                    <div class="ap-img-strip-item">
                      <img src={src} alt={`Production still from ${data.title}`} class="ap-img" style={`object-position: ${i === 0 ? imagePos : 'center 20%'}`} />
                    </div>
                  ))}
                </div>
                <button class="ap-strip-btn ap-strip-prev" aria-label="Previous image" hidden>←</button>
                <button class="ap-strip-btn ap-strip-next" aria-label="Next image">→</button>
              </div>
            )}

          </div>
        ))}
      </div>
    ))}
  </div>

  {/* <section class="books-rail-section">
    <BooksRail />
  </section> */}

</Layout>

<script>
  // Fade in images on load, remove on error
  document.querySelectorAll<HTMLImageElement>('.ap-img').forEach(img => {
    const show = () => { img.style.opacity = '1'; };
    const hide = () => {
      const stripItem = img.closest('.ap-img-strip-item') as HTMLElement | null;
      if (stripItem) { stripItem.remove(); return; }
      (img.closest('.ap-img-wrap') as HTMLElement | null)?.remove();
    };
    if (img.complete) { img.naturalWidth ? show() : hide(); }
    else { img.addEventListener('load', show); img.addEventListener('error', hide); }
  });

  // Strip nav arrows
  document.querySelectorAll<HTMLElement>('.ap-img-strip-wrap').forEach(wrap => {
    const strip = wrap.querySelector<HTMLElement>('.ap-img-strip');
    const prev = wrap.querySelector<HTMLButtonElement>('.ap-strip-prev');
    const next = wrap.querySelector<HTMLButtonElement>('.ap-strip-next');
    const items = wrap.querySelectorAll<HTMLElement>('.ap-img-strip-item');
    if (!strip || !prev || !next || !items.length) return;

    let current = 0;

    const go = (index: number) => {
      current = Math.max(0, Math.min(index, items.length - 1));
      strip.scrollTo({ left: items[0].offsetWidth * current + 6 * current, behavior: 'smooth' });
      prev.hidden = current === 0;
      next.hidden = current === items.length - 1;
    };

    prev.addEventListener('click', () => go(current - 1));
    next.addEventListener('click', () => go(current + 1));
  });
</script>

<style>
  .ap-page {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Novel group */
  .ap-group {
    border-top: 1.5px solid var(--text);
    margin-bottom: 56px;
  }

  .ap-group-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 16px 0 24px;
  }

  .ap-novel-title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-style: italic;
    font-weight: 400;
    color: var(--text);
    line-height: var(--lh-tight);
    letter-spacing: var(--track-tight);
  }

  .ap-count {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-faint);
    flex-shrink: 0;
    margin-left: 16px;
  }

  /* Entry row */
  .ap-entry {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0 36px;
    border-top: 1px solid var(--rule);
    padding: 18px 0;
    align-items: start;
  }

  .ap-entry--has-image {
    grid-template-columns: 120px 1fr 260px;
  }

  /* Meta column */
  .ap-meta {
    display: flex;
    flex-direction: column;
    padding-top: 3px;
  }

  .ap-country {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    line-height: 1.5;
  }

  .ap-medium,
  .ap-year {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* Content column */
  .ap-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 400;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 3px;
  }

  .ap-network {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-faint);
  }

  .ap-status {
    color: var(--text-faint);
    font-size: var(--text-xs);
    font-style: italic;
  }

  .ap-award {
    display: flex;
    align-items: baseline;
    gap: 7px;
    margin-top: 8px;
  }

  .ap-award-dash {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-faint);
    flex-shrink: 0;
  }

  .ap-award-text {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.5;
  }

  .ap-award-more {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-faint);
    flex-shrink: 0;
  }

  /* Links */
  .ap-links {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 2px 0;
    margin-top: 10px;
  }

  .ap-link {
    font-family: var(--font-body);
    font-size: 12.5px;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    line-height: 1.6;
  }

  .ap-link:hover { opacity: 0.7; }

  .ap-sep {
    color: var(--rule);
    font-size: var(--text-xs);
    margin: 0 8px;
    line-height: 1.6;
  }

  /* Image column — single */
  .ap-img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 4px;
  }

  .ap-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.2s;
  }

  /* Image column — scroll strip */
  .ap-img-strip-wrap {
    width: 100%;
    position: relative;
  }

  .ap-img-strip {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 6px;
  }

  .ap-img-strip::-webkit-scrollbar {
    display: none;
  }

  .ap-img-strip-item {
    flex: 0 0 100%;
    scroll-snap-align: start;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 4px;
  }

  .ap-img-strip-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .ap-strip-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 28px;
    height: 28px;
    background: var(--bg);
    border: 0.5px solid var(--rule);
    color: var(--text);
    font-size: 13px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 2px;
  }

  .ap-strip-btn:hover { background: var(--bg-alt); }
  .ap-strip-prev { left: 6px; }
  .ap-strip-next { right: 6px; }

  /* Responsive */
  @media (max-width: 860px) {
    .ap-entry--has-image {
      grid-template-columns: 90px 1fr;
      grid-template-rows: auto auto;
    }

    .ap-entry--has-image .ap-img-wrap,
    .ap-entry--has-image .ap-img-strip-wrap {
      grid-column: 1 / -1;
      max-width: 320px;
      margin-top: 12px;
    }

    .ap-strip-btn {
      width: 36px;
      height: 36px;
    }
  }

  @media (max-width: 480px) {
    .ap-entry,
    .ap-entry--has-image {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* Reorder: meta → image → content */
    .ap-meta {
      order: 1;
      margin-bottom: 10px;
    }

    .ap-img-wrap,
    .ap-img-strip-wrap {
      order: 2;
      grid-column: 1 !important;
      max-width: 100% !important;
      margin: 0 0 12px !important;
    }

    .ap-content {
      order: 3;
    }

    /* Meta strip: horizontal with · separators */
    .ap-meta {
      flex-direction: row;
      align-items: center;
      gap: 0;
    }

    .ap-medium::before,
    .ap-year::before {
      content: ' · ';
      opacity: 0.5;
    }

    /* Larger mobile type */
    .ap-title { font-size: 22px; line-height: var(--lh-snug); }
    .ap-network { font-size: 15px; }
    .ap-country, .ap-medium, .ap-year { font-size: 14px; }

    /* Links: border separator + 44px touch height */
    .ap-links {
      border-top: 1px solid #F0F0F0;
      padding-top: 12px;
      margin-top: 10px;
    }

    .ap-link {
      font-size: 15px;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }

    .ap-strip-btn {
      width: 40px;
      height: 40px;
      font-size: 15px;
    }
  }
</style>
