---
import Layout from '../layouts/Layout.astro';
import PageHeading from '../components/PageHeading.astro';
import AdaptationEntry from '../components/AdaptationEntry.astro';
import { getCollection } from 'astro:content';

const allAdaptations = await getCollection('adaptations');

const countries = [...new Set(allAdaptations.map(a => a.data.country))];
const countriesText = countries.length <= 2
  ? countries.join(' and ')
  : countries.slice(0, -1).join(', ') + ', and ' + countries[countries.length - 1];

const allEntries = [...allAdaptations].sort((a, b) => {
  const aHasYear = a.data.year != null;
  const bHasYear = b.data.year != null;
  if (!aHasYear && bHasYear) return -1;
  if (aHasYear && !bHasYear) return 1;
  if (!aHasYear && !bHasYear) return a.data.slug.localeCompare(b.data.slug);
  if (a.data.year !== b.data.year) return b.data.year! - a.data.year!;
  if (a.data.order !== b.data.order) return a.data.order - b.data.order;
  return a.data.slug.localeCompare(b.data.slug);
});
---

<Layout title="Adaptations" lang="en">

  <PageHeading
    eyebrow="Adaptations"
    title="On screen and on stage"
    subtitle={`Television and stage adaptations of Noa Yedlin's novels, across ${countriesText}.`}
  />

  <div class="ap-page">
    <div class="ap-group">
      {allEntries.map((entry) => (
        <AdaptationEntry data={entry.data} />
      ))}
    </div>
  </div>

</Layout>

<style>
  .ap-page {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .ap-group {
    margin-bottom: 56px;
  }
</style>
