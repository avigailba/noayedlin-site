---
import Layout from '../layouts/Layout.astro';
import PageHeading from '../components/PageHeading.astro';
import BooksRail from '../components/BooksRail.astro';
import { getCollection } from 'astro:content';

const allAdaptations = await getCollection('adaptations');
const allBooks = await getCollection('booksEn');

const bookMap = Object.fromEntries(allBooks.map(b => [b.data.slug, b.data]));

const groups = allAdaptations.reduce((acc, a) => {
  const key = a.data.source_book;
  if (!acc[key]) acc[key] = [];
  acc[key].push(a);
  return acc;
}, {} as Record<string, typeof allAdaptations>);

Object.values(groups).forEach(g => g.sort((a, b) => a.data.order - b.data.order));

const sortedGroups = Object.entries(groups).sort(([slugA], [slugB]) => {
  return (bookMap[slugA]?.order ?? 999) - (bookMap[slugB]?.order ?? 999);
});
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const countries = [...new Set(allAdaptations.map(a => a.data.country))];
const countriesText = countries.length <= 2
  ? countries.join(' and ')
  : countries.slice(0, -1).join(', ') + ', and ' + countries[countries.length - 1];

---

<Layout title="Adaptations" lang="en">

  <PageHeading eyebrow="Adaptations" title="On screen and on stage." subtitle={`Television and stage adaptations of Noa Yedlin's novels — across ${countriesText}.`} />

  <div class="ap-intro">
    <p>Yedlin is the creator of a two-season TV series based on her bestselling novel <em>Stockholm</em>, winner of the Israeli Best Mini-Series TV Award. A German remake, <em>You Don't Die Among Friends</em>, won Best Scripted Format at the 2021 International Format Awards and Best European Series at La Rochelle Festival De La Fiction 2021. The series has been adapted in three countries: Israel, Germany, and Sweden. Her novel <em>People Like Us</em> is currently in development for Israeli television, and a stage adaptation of <em>House Arrest</em> is playing at Beit Lessin Theater in Tel Aviv.</p>
  </div>

  {sortedGroups.map(([slug, adaptationList]) => {
    const book = bookMap[slug];
    if (!book) return null;
    return (
      <div class="ap-group">
        <div class="ap-group-heading">
          <span class="eyebrow ap-from-label">From the novel</span>
          <h2 class="ap-group-title">
            <a href={`${base}/books/${slug}`} class="headline-link"><em>{book.title}</em></a>
          </h2>
        </div>

        <div class="ap-cards">
          {adaptationList.map((a) => {
            const stillStyle = a.data.still?.image
              ? ''
              : a.data.still?.gradient
                ? `background: linear-gradient(135deg, ${a.data.still.gradient[0]}, ${a.data.still.gradient[1]});`
                : 'background: #2A2A2A;';
            const longTitle = a.data.title.length > 24;
            return (
              <article class={`ap-card${a.data.still?.image ? ' ap-card--has-thumb' : ''}`}>

                {a.data.still?.image && (
                  <div class="ap-card-thumb">
                    <img src={a.data.still.image} alt={a.data.title} style={a.data.still.position ? `object-position: ${a.data.still.position}` : undefined} />
                  </div>
                )}

                <div class="ap-content">
                  <p class="ap-meta">
                    {[a.data.country, a.data.medium, a.data.year].filter(Boolean).join(' · ')}
                  </p>
                  <h3 class={`ap-card-title${longTitle ? ' ap-card-title--sm' : ''}`}>
                    {a.data.title}
                  </h3>
                  {a.data.network && (
                    <p class="ap-network">
                      {a.data.network}{a.data.episodes ? ` · ${a.data.episodes} episodes` : ''}
                    </p>
                  )}
                  {a.data.awards && a.data.awards.length > 0 && (
                    <div class="ap-awards">
                      {a.data.awards.map((award: string) => (
                        <p class="ap-award">
                          <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                            <polygon points="6,0 7.5,4.5 12,4.5 8.5,7 9.8,11.5 6,9 2.2,11.5 3.5,7 0,4.5 4.5,4.5" fill="var(--text-muted)" />
                          </svg>
                          {award}
                        </p>
                      ))}
                    </div>
                  )}
                  {a.data.synopsis && (
                    <p class="ap-synopsis">{a.data.synopsis}</p>
                  )}
                  {a.data.watch && a.data.watch.length > 0 && (
                    <div class="ap-watch">
                      {a.data.watch.map((w) => (
                        <a href={w.url} target="_blank" rel="noopener" class={w.primary ? 'btn-primary' : 'btn-secondary'}>
                          {w.label}
                        </a>
                      ))}
                    </div>
                  )}
                  {a.data.press && a.data.press.length > 0 && (
                    <div class="ap-press">
                      <div class="ap-press-links">
                        {a.data.press.map((p) => (
                          <a href={p.url} target="_blank" rel="noopener" class="ap-press-link">{p.label}</a>
                        ))}
                      </div>
                    </div>
                  )}
                </div>

                {(() => {
                  const galleryStills = (a.data.stills ?? []).filter((src: string) => src !== a.data.still?.image);
                  return galleryStills.length > 0 ? (
                    <div class="ap-group-stills">
                      {galleryStills.map((src: string) => (
                        <figure class="ap-stills-item">
                          <a href={src} target="_blank" rel="noopener" class="ap-stills-link" title="View full size">
                            <img src={src} alt="" loading="lazy" />
                            <span class="ap-stills-zoom" aria-hidden="true">↗</span>
                          </a>
                        </figure>
                      ))}
                    </div>
                  ) : null;
                })()}
              </article>
            );
          })}
        </div>
      </div>
    );
  })}

  <section class="books-rail-section">
    <BooksRail />
  </section>

</Layout>

<style>
  /* Intro paragraph */
  .ap-intro {
    max-width: var(--max-width);
    margin: 0 auto 48px;
  }

  .ap-intro p {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-loose);
    color: var(--text);
    margin: 0;
  }

  /* Production stills — bottom of each book group */
  .ap-group-stills {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 4px;
    margin-top: 20px;
  }

  .ap-stills-item {
    margin: 0;
    padding: 0;
  }

  .ap-stills-link {
    display: block;
    position: relative;
    overflow: hidden;
  }

  .ap-stills-link img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: opacity 0.15s;
  }

  .ap-stills-zoom {
    position: absolute;
    top: 6px;
    right: 6px;
    font-size: 11px;
    line-height: 1;
    color: #fff;
    opacity: 0;
    transition: opacity 0.15s;
    background: rgba(0,0,0,0.45);
    padding: 3px 5px;
  }

  .ap-stills-link:hover img { opacity: 0.85; }
  .ap-stills-link:hover .ap-stills-zoom { opacity: 1; }

  @media (max-width: 680px) {
    .ap-group-stills {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Group heading */
  .ap-group {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    align-items: start;
  }

  .ap-group + .ap-group {
    border-top: 0.5px solid var(--rule);
  }

  .ap-group-heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 48px 0 0;
    position: sticky;
    top: calc(var(--header-h, 68px) + 24px);
  }

  @media (max-width: 768px) {
    .ap-group {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .ap-group-heading {
      position: static;
      padding: 40px 0 0;
    }
  }

  .ap-from-label {
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .ap-group-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-style: italic;
    font-weight: 400;
    letter-spacing: var(--track-tight);
    line-height: var(--lh-tight);
    color: var(--text);
    margin: 0 0 18px;
  }

  /* Cards */
  .ap-cards {
    display: flex;
    flex-direction: column;
    padding-top: 48px;
  }

  .ap-card {
    padding: 24px 0;
  }

  .ap-card--has-thumb {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 32px;
    align-items: start;
  }

  .ap-card-thumb {
    width: 320px;
  }

  .ap-card-thumb img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  /* stills gallery spans both columns */
  .ap-card--has-thumb .ap-group-stills {
    grid-column: 1 / -1;
  }

  @media (max-width: 680px) {
    .ap-card--has-thumb {
      grid-template-columns: 1fr;
    }
    .ap-card-thumb { width: 100%; }
  }


  /* Content column */
  .ap-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 2px;
  }

  .ap-meta {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    margin: 0;
  }

  .ap-card-title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: var(--track-tight);
    line-height: var(--lh-tight);
    margin: 0;
    color: var(--text);
  }

  .ap-network {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
  }

  .ap-awards {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ap-award {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text);
    margin: 0;
  }

  .ap-synopsis {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-sm);
    line-height: var(--lh-snug);
    color: var(--text);
    margin: 0 0 4px;
  }

  /* Watch buttons */
  .ap-watch {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  /* Press */
  .ap-press {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 4px;
  }

  .ap-press-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .ap-press-link {
    font-size: var(--text-xs);
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 2px;
    letter-spacing: var(--track-none);
  }

</style>
