---
import Layout from '../layouts/Layout.astro';
import BooksRail from '../components/BooksRail.astro';
import { getCollection } from 'astro:content';

const allAdaptations = await getCollection('adaptations');
const allBooks = await getCollection('booksEn');

const bookMap = Object.fromEntries(allBooks.map(b => [b.data.slug, b.data]));

const groups = allAdaptations.reduce((acc, a) => {
  const key = a.data.source_book;
  if (!acc[key]) acc[key] = [];
  acc[key].push(a);
  return acc;
}, {} as Record<string, typeof allAdaptations>);

Object.values(groups).forEach(g => g.sort((a, b) => a.data.order - b.data.order));

const sortedGroups = Object.entries(groups).sort(([slugA], [slugB]) => {
  return (bookMap[slugA]?.order ?? 999) - (bookMap[slugB]?.order ?? 999);
});

const countries = [...new Set(allAdaptations.map(a => a.data.country))];
const countriesText = countries.length <= 2
  ? countries.join(' and ')
  : countries.slice(0, -1).join(', ') + ', and ' + countries[countries.length - 1];
---

<Layout title="Adaptations" lang="en">

  <header class="page-heading">
    <p class="eyebrow">Adaptations</p>
    <h1>On screen and on stage</h1>
    <p class="page-heading-intro">Television and stage adaptations of Noa Yedlin's novels — across {countriesText}.</p>
  </header>
  <hr class="page-rule" />

  {sortedGroups.map(([slug, adaptationList]) => {
    const book = bookMap[slug];
    if (!book) return null;
    return (
      <div class="ap-group">
        <div class="ap-group-heading">
          <div class="ap-group-left">
            <span class="eyebrow ap-from-label">From the novel</span>
            <a href={`/books/${slug}`} class="ap-book-link">
              <em>{book.title}</em><span class="ap-arrow">→</span>
            </a>
          </div>
        </div>

        <div class="ap-cards">
          {adaptationList.map((a) => {
            const stillStyle = a.data.still?.image
              ? ''
              : a.data.still?.gradient
                ? `background: linear-gradient(135deg, ${a.data.still.gradient[0]}, ${a.data.still.gradient[1]});`
                : 'background: #2A2A2A;';
            const longTitle = a.data.title.length > 24;
            return (
              <article class="ap-card">

                <div class="ap-still" style={stillStyle}>
                  {a.data.still?.image && (
                    <img src={a.data.still.image} alt={a.data.title} />
                  )}
                  <div class="ap-still-overlay"></div>
                  <span class="ap-still-network">
                    {[a.data.network, a.data.country].filter(Boolean).join(' · ')}
                  </span>
                  <span class={`ap-still-title${longTitle ? ' ap-still-title--sm' : ''}`}>
                    {a.data.title}
                  </span>
                  {a.data.medium !== 'Stage play' && (
                    <span class="ap-play-circle" aria-hidden="true">
                      <svg width="10" height="12" viewBox="0 0 10 12">
                        <polygon points="0,0 10,6 0,12" fill="currentColor" />
                      </svg>
                    </span>
                  )}
                </div>

                <div class="ap-content">
                  <p class="ap-meta">
                    {[a.data.country, a.data.medium, a.data.year].filter(Boolean).join(' · ')}
                  </p>
                  <h3 class={`ap-card-title${longTitle ? ' ap-card-title--sm' : ''}`}>
                    {a.data.title}
                  </h3>
                  {a.data.network && (
                    <p class="ap-network">
                      {a.data.network}{a.data.episodes ? ` · ${a.data.episodes} episodes` : ''}
                    </p>
                  )}
                  {a.data.award && (
                    <p class="ap-award">
                      <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                        <polygon points="6,0 7.5,4.5 12,4.5 8.5,7 9.8,11.5 6,9 2.2,11.5 3.5,7 0,4.5 4.5,4.5" fill="var(--accent)" />
                      </svg>
                      {a.data.award}
                    </p>
                  )}
                  {a.data.synopsis && (
                    <p class="ap-synopsis">{a.data.synopsis}</p>
                  )}
                  {a.data.watch && a.data.watch.length > 0 && (
                    <div class="ap-watch">
                      {a.data.watch.map((w) => (
                        <a href={w.url} target="_blank" rel="noopener" class={w.primary ? 'btn-primary' : 'btn-secondary'}>
                          {w.label}
                        </a>
                      ))}
                    </div>
                  )}
                  {a.data.press && a.data.press.length > 0 && (
                    <div class="ap-press">
                      <span class="eyebrow ap-press-label">Press</span>
                      <div class="ap-press-links">
                        {a.data.press.map((p) => (
                          <a href={p.url} target="_blank" rel="noopener" class="ap-press-link">{p.label}</a>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </div>
    );
  })}

  <BooksRail divider />

</Layout>

<style>
  /* Group heading */
  .ap-group {
    max-width: 860px;
    margin: 0 auto;
  }

  .ap-group-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 48px 0 8px;
  }

  .ap-group-left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .ap-from-label {
    color: var(--text-muted);
  }

  .ap-book-link {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-style: italic;
    font-weight: 400;
    letter-spacing: var(--track-tight);
    line-height: var(--lh-tight);
    color: var(--text);
    text-decoration: none;
  }

  .ap-book-link:hover { opacity: 0.7; }

  .ap-arrow {
    font-style: normal;
    font-size: 1.125rem;
    color: var(--accent);
    margin-left: 6px;
    vertical-align: 2px;
  }

  .ap-count {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* Cards */
  .ap-cards {
    display: flex;
    flex-direction: column;
  }

  .ap-card {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 28px;
    align-items: start;
    padding: 24px 0;
    border-top: 0.5px solid var(--rule);
  }

  .ap-cards .ap-card:last-child {
    border-bottom: 0.5px solid var(--rule);
  }

  /* Still panel */
  .ap-still {
    width: 240px;
    aspect-ratio: 16/9;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ap-still img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ap-still-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 55%, transparent 100%);
  }

  .ap-still-network {
    position: absolute;
    top: 10px;
    left: 10px;
    font-family: var(--font-serif);
    font-size: var(--text-xs);
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: rgba(245, 245, 242, 0.75);
    z-index: 1;
    line-height: 1;
  }

  .ap-still-title {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 40px;
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    line-height: var(--lh-tight);
    color: rgba(245, 245, 242, 0.95);
    z-index: 1;
  }

  .ap-still-title--sm {
    font-size: var(--text-xs);
  }

  .ap-play-circle {
    position: absolute;
    bottom: 12px;
    right: 12px;
    width: 22px;
    height: 22px;
    border: 1px solid rgba(245, 245, 242, 0.8);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(245, 245, 242, 0.8);
    z-index: 1;
    padding-left: 2px;
  }

  /* Content column */
  .ap-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 2px;
  }

  .ap-meta {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    margin: 0;
  }

  .ap-card-title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: var(--track-tight);
    line-height: var(--lh-tight);
    margin: 0;
    color: var(--text);
  }

  .ap-card-title--sm {
    font-size: var(--text-lg);
  }

  .ap-network {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
  }

  .ap-award {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--accent);
    margin: 0 0 2px;
  }

  .ap-synopsis {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-sm);
    line-height: var(--lh-snug);
    color: #2A2A2A;
    margin: 0 0 4px;
  }

  /* Watch buttons */
  .ap-watch {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  /* Press */
  .ap-press {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 4px;
  }

  .ap-press-label {
    color: var(--text-muted);
  }

  .ap-press-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .ap-press-link {
    font-size: var(--text-xs);
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 2px;
    letter-spacing: var(--track-none);
  }

  @media (max-width: 680px) {
    .ap-card {
      grid-template-columns: 1fr;
    }
    .ap-still {
      width: 100%;
    }
    .ap-group-heading {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
