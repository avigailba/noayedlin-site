---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Adaptations" lang="en">
  <h1>Adaptations</h1>
  <div class="adaptations-list">
    <div class="adaptation-item">
      <h3>Stockholm – Israeli TV Series</h3>
      <p>Two-season Israeli series based on the novel. Winner of the Israeli Best Mini-Series TV Award.</p>
    </div>
    <div class="adaptation-item">
      <h3>You Don't Die Among Friends – German Remake</h3>
      <p>
        German adaptation of the Stockholm series. Winner of Best Scripted Format at the 2021
        International Format Awards and Best European Series at La Rochelle Festival De La Fiction 2021.
      </p>
    </div>
    <div class="adaptation-item">
      <h3>Stockholm – Swedish Remake (SVT)</h3>
      <p>Remake produced by SVT Sweden, broadcast in 2022.</p>
    </div>
    <div class="adaptation-item">
      <h3>People Like Us – Israeli Series (In Development)</h3>
      <p>Currently being developed as a TV series in Israel.</p>
    </div>
    <div class="adaptation-item">
      <h3>House Arrest – Stage Adaptation</h3>
      <p>Stage adaptation now playing at Beit Lessin Theater, Tel Aviv.</p>
    </div>
  </div>
</Layout>
