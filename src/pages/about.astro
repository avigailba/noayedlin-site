---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const about = await getEntry('about', 'about');
const { heading, tagline, portrait, lead, bio, awards, representation } = about.data;
---

<Layout title="About" lang="en">
  <div class="ab-hero">
    <div class="ab-col1">
      <p class="ab-eyebrow">About</p>
      <h1 class="ab-title">{heading}</h1>
      <p class="ab-tagline">{tagline}</p>

      <div class="ab-body">
        <p class="ab-lead" set:html={lead} />
        {bio.map((p) => <p class="ab-bio-para" set:html={p} />)}
      </div>
    </div>
    <div class="ab-col2">
      <img src={portrait} alt={heading} class="ab-portrait" />
    </div>
  </div>

  <div class="ab-awards-band">
    <ul class="ab-awards-list">
      {awards.map((a) => <li class="award-badge">{a}</li>)}
    </ul>
  </div>

  <div class="ab-section">
    <div class="ab-rep-grid">
      {representation.map((r) => (
        <div class="ab-rep-entry">
          <p class="ab-rep-role">{r.role}</p>
          {r.name && <p class="ab-rep-name">{r.name}</p>}
          {r.phone && <p class="ab-rep-name">{r.phone}</p>}
          {r.url && (
            <a href={r.url} target="_blank" rel="noopener" class="ab-rep-link">
              {r.urlLabel ?? r.url} →
            </a>
          )}
        </div>
      ))}
    </div>
  </div>

  {/* <section class="books-rail-section">
    <BooksRail />
  </section> */}
</Layout>

<style>
  /* ── Hero 2-column layout ── */
  .ab-hero {
    display: grid;
    grid-template-columns: 1fr 30%;
    gap: 32px;
    align-items: start;
    padding: 32px 0 56px;
  }

  /* ── Heading block (replicates PageHeading styles) ── */
  .ab-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 14px;
  }

  .ab-title {
    font-family: var(--font-serif);
    font-size: 96px;
    line-height: 0.92;
    letter-spacing: -0.035em;
    font-weight: 400;
    color: var(--text);
    text-align: left;
    margin: 0 0 22px;
  }

  .ab-tagline {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-snug);
    color: var(--text-muted);
    max-width: 460px;
    margin: 0 0 2.5rem;
  }

  /* ── Portrait ── */
  .ab-portrait {
    width: 100%;
    display: block;
    filter: grayscale(100%);
    margin-top: 30px;
  }

  /* ── Bio text ── */
  .ab-lead {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-loose);
    color: var(--text);
    margin-bottom: 1.75rem;
  }

.ab-bio-para {
    font-size: var(--text-md);
    line-height: var(--lh-loose);
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  /* ── Awards band ── */
  .ab-awards-band {
    background: var(--bg-alt);
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    padding: 2.5rem max(32px, calc((100vw - 1100px) / 2 + 32px));
    margin-bottom: 3.5rem;
  }

  @media (max-width: 600px) {
    .ab-awards-band {
      padding-left: 20px;
      padding-right: 20px;
    }
  }

  .ab-awards-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .ab-awards-list .award-badge {
    font-size: var(--text-xs);
  }

  /* ── Representation ── */
  .ab-section {
    margin-bottom: 3.5rem;
  }

  .ab-rep-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem 3rem;
  }

  .ab-rep-entry {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .ab-rep-role {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    margin: 0;
  }

  .ab-rep-name {
    font-size: var(--text-md);
    margin: 0.15rem 0 0;
    color: var(--text);
  }

  .ab-rep-link {
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    align-self: flex-start;
    margin-top: 0.15rem;
  }

  .ab-rep-link:hover { opacity: 0.7; }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .ab-hero {
      grid-template-columns: 1fr;
      padding-bottom: 40px;
    }
    .ab-col2 {
      order: -1;
    }
    .ab-portrait {
      max-width: 280px;
      margin: 0 auto;
    }
    .ab-title {
      font-size: clamp(48px, 12vw, 96px);
      margin-bottom: 16px;
    }
    .ab-rep-grid { grid-template-columns: 1fr; }
  }
</style>
