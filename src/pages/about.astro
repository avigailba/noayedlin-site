---
import Layout from '../layouts/Layout.astro';
import BooksRail from '../components/BooksRail.astro';
import { getEntry } from 'astro:content';

const about = await getEntry('about', 'about');
const { heading, tagline, portrait, lead, bio, awards, representation } = about.data;
---

<Layout title="About" lang="en">
  <div class="ab-hero">
    <div class="ab-hero-text">
      <p class="eyebrow">About</p>
      <h1 class="ab-name">{heading}</h1>
      <p class="ab-tagline">{tagline}</p>
    </div>
    <div class="ab-portrait-wrap">
      <img src={portrait} alt={heading} class="ab-portrait" />
    </div>
  </div>

  <hr class="page-rule" />

  <div class="ab-body">
    <p class="ab-lead" set:html={lead} />
    {bio.map((p) => <p class="ab-bio-para" set:html={p} />)}
  </div>

  <div class="ab-awards-band">
    <p class="eyebrow ab-band-eyebrow">Awards &amp; Recognition</p>
    <ul class="ab-awards-list">
      {awards.map((a) => <li class="award-badge">{a}</li>)}
    </ul>
  </div>

  <div class="ab-section">
    <p class="section-title">Representation</p>
    <div class="ab-rep-grid">
      {representation.map((r) => (
        <div class="ab-rep-entry">
          <p class="ab-rep-role">{r.role}</p>
          {r.name && <p class="ab-rep-name">{r.name}</p>}
          {r.phone && <p class="ab-rep-name">{r.phone}</p>}
          {r.url && (
            <a href={r.url} target="_blank" rel="noopener" class="ab-rep-link">
              {r.urlLabel ?? r.url} →
            </a>
          )}
        </div>
      ))}
    </div>
  </div>

  <BooksRail />
</Layout>

<style>
  .ab-hero {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 4rem;
    padding: 56px 0;
    align-items: start;
  }

  .ab-hero-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.25rem;
  }

  .ab-hero-text .eyebrow {
    color: var(--accent);
    margin-bottom: 14px;
  }

  .ab-name {
    text-align: left;
    font-family: var(--font-serif);
    font-size: 96px;
    letter-spacing: -0.035em;
    line-height: 0.92;
    font-weight: 400;
    margin: 0 0 22px;
  }

  @media (max-width: 768px) {
    .ab-name { font-size: clamp(48px, 12vw, 96px); }
  }

  .ab-tagline {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--text-muted);
    margin: 0;
    line-height: var(--lh-snug);
    max-width: 460px;
  }

  .ab-hero-awards {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }

  .ab-portrait-wrap {
    position: relative;
  }

  .ab-portrait {
    width: 100%;
    display: block;
    filter: grayscale(100%);
  }

  .ab-body {
    max-width: 620px;
    margin: 3rem auto;
  }

  .ab-lead {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: var(--lh-loose);
    color: var(--text);
    margin-bottom: 1.75rem;
  }

  .ab-lead::first-letter {
    font-family: var(--font-serif);
    font-size: 3.8em;
    line-height: 0.75;
    float: left;
    margin-right: 0.07em;
    margin-top: 0.06em;
    color: var(--text);
  }

  .ab-bio-para {
    font-size: var(--text-md);
    line-height: var(--lh-loose);
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .ab-awards-band {
    background: var(--bg-alt);
    margin: 0 calc(-1 * var(--spacing));
    padding: 2.5rem var(--spacing);
    margin-bottom: 3.5rem;
  }

  .ab-band-eyebrow {
    margin-bottom: 1.25rem;
  }

  .ab-awards-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .ab-awards-list .award-badge {
    font-size: var(--text-xs);
  }

  .ab-section {
    margin-bottom: 3.5rem;
  }

  .ab-rep-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem 3rem;
  }

  .ab-rep-entry {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .ab-rep-role {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-wide);
    color: var(--text-muted);
    margin: 0;
  }

  .ab-rep-name {
    font-size: var(--text-md);
    margin: 0.15rem 0 0;
    color: var(--text);
  }

  .ab-rep-link {
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    align-self: flex-start;
    margin-top: 0.15rem;
  }

  .ab-rep-link:hover { opacity: 0.7; }

  @media (max-width: 760px) {
    .ab-hero {
      grid-template-columns: 1fr;
      padding: 40px 0;
    }
    .ab-portrait-wrap { display: none; }
    .ab-rep-grid { grid-template-columns: 1fr; }
    .ab-books-rail { grid-template-columns: repeat(2, 1fr); }
  }
</style>
