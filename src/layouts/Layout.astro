---
import '../styles/global.css';
import MobileNav from '../components/MobileNav.astro';

interface Props {
  title: string;
  lang: 'en' | 'he';
  description?: string;
}

const { title, lang, description = 'Noa Yedlin – Israeli novelist and screenwriter' } = Astro.props;

const isHe = lang === 'he';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rawPath = Astro.url.pathname;
const currentPath = (rawPath.startsWith(base) ? rawPath.slice(base.length) : rawPath) || '/';

const nav = isHe
  ? [
      { label: 'בית', href: '/he' },
      { label: 'ספרים', href: '/he/books' },
      { label: 'עיבודים', href: '/he/adaptations' },
      { label: 'אירועים', href: '/he/events' },
      { label: 'תקשורת', href: '/he/media' },
      { label: 'אודות', href: '/he/about' },
      { label: 'צור קשר', href: '/he/contact' },
    ]
  : [
      { label: 'Home', href: '/' },
      { label: 'Books', href: '/books' },
      { label: 'Adaptations', href: '/adaptations' },
      { label: 'Events', href: '/events' },
      { label: 'Media', href: '/media' },
      { label: 'About', href: '/about' },
      { label: 'Contact', href: '/contact' },
      { label: 'Design', href: '/design' },
    ];

const altLangHref = isHe ? '/' : '/he';
---

<!doctype html>
<html lang={lang} dir={isHe ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={base + '/favicon.ico'} />
    <title>{title} – Noa Yedlin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-inner">
        <a href={base + (isHe ? '/he' : '/')} class="site-title">
          {isHe ? 'נועה ידלין' : 'Noa Yedlin'}
        </a>
        <ul class="nav-links">
          {nav.map(({ label, href }) => (
            <li>
              <a href={base + href} aria-current={(href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(href + '/')) ? 'page' : undefined}>
                {label}
              </a>
            </li>
          ))}
        </ul>
        <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>
      </nav>
    </header>

    <MobileNav nav={nav} currentPath={currentPath} />

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-col">
          <p class="footer-heading">{isHe ? 'ספרים' : 'Books'}</p>
          <ul>
            {isHe ? (
              <>
                <li><a href={base + '/he/books/stockholm'}>סטוקהולם</a></li>
                <li><a href={base + '/he/books/house-arrest'}>מעצר בית</a></li>
                <li><a href={base + '/he/books/people-like-us'}>אנשים כמונו</a></li>
                <li><a href={base + '/he/books/the-wrong-book'}>הספר הלא נכון</a></li>
              </>
            ) : (
              <>
                <li><a href={base + '/books/stockholm'}>Stockholm</a></li>
                <li><a href={base + '/books/house-arrest'}>House Arrest</a></li>
                <li><a href={base + '/books/people-like-us'}>People Like Us</a></li>
                <li><a href={base + '/books/the-wrong-book'}>The Wrong Book</a></li>
              </>
            )}
          </ul>
        </div>

        <div class="footer-col">
          <p class="footer-heading">{isHe ? 'ניווט' : 'Navigate'}</p>
          <ul>
            {isHe ? (
              <>
                <li><a href={base + '/he/books'}>ספרים</a></li>
                <li><a href={base + '/he/events'}>הרצאות ואירועים</a></li>
                <li><a href={base + '/he/media'}>תקשורת</a></li>
                <li><a href={base + '/he/about'}>אודות</a></li>
              </>
            ) : (
              <>
                <li><a href={base + '/books'}>Books</a></li>
                <li><a href={base + '/events'}>Lectures &amp; Events</a></li>
                <li><a href={base + '/media'}>Media</a></li>
                <li><a href={base + '/about'}>About</a></li>
              </>
            )}
          </ul>
        </div>

        <div class="footer-col">
          <p class="footer-heading">{isHe ? 'ייצוג' : 'Representatives'}</p>
          <ul>
            {isHe ? (
              <>
                <li><a href="https://www.curtisbrown.co.uk/client/noa-yedlin" target="_blank" rel="noopener">ספרותי – Curtis Brown</a></li>
                <li><a href="https://lionhouseagency.com/noa-yedlin" target="_blank" rel="noopener">סוכן הרצאות – ארה"ב</a></li>
              </>
            ) : (
              <>
                <li><a href="https://www.curtisbrown.co.uk/client/noa-yedlin" target="_blank" rel="noopener">Literary – Curtis Brown</a></li>
                <li><a href="https://lionhouseagency.com/noa-yedlin" target="_blank" rel="noopener">Lecture Agent – USA</a></li>
              </>
            )}
          </ul>
        </div>

      </div>

      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} Noa Yedlin. {isHe ? 'כל הזכויות שמורות.' : 'All rights reserved.'}</p>
        {!isHe && <p><a href={base + '/accessibility'}>Accessibility Statement</a></p>}
      </div>
    </footer>
  </body>
  <script define:vars={{ base }}>
    // Sticky header scroll shadow
    const header = document.querySelector('.site-header');
    if (header) {
      const update = () => header.classList.toggle('scrolled', window.scrollY > 8);
      window.addEventListener('scroll', update, { passive: true });
      update();
    }

    // Nav active state — client-side fallback using actual browser pathname
    const currentPath = (window.location.pathname.startsWith(base)
      ? window.location.pathname.slice(base.length)
      : window.location.pathname).replace(/\/$/, '') || '/';
    document.querySelectorAll('.nav-links a, .mobile-nav-link').forEach(function(link) {
      const fullHref = link.getAttribute('href') ?? '';
      const href = (fullHref.startsWith(base) ? fullHref.slice(base.length) : fullHref).replace(/\/$/, '') || '/';
      const isActive = href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(href + '/');
      if (isActive) {
        link.setAttribute('aria-current', 'page');
        link.classList.add('is-active');
      } else {
        link.removeAttribute('aria-current');
        link.classList.remove('is-active');
      }
    });
  </script>
</html>
